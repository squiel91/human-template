<section class="tiendu-main-page" style="padding: 48px 0;">
    <div style="padding: 0 8px;">
        <div style="max-width: 1024px; margin: 0 auto;">
            {% if section.blocks and section.blocks.size > 0 %}
                {% content_for 'blocks' %}
            {% elsif design_mode or preview_mode %}
                <div>Agrega bloques para construir la página.</div>
            {% endif %}
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Página principal",
    "enabled_on": {
        "templates": ["page"]
    },
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "layout"
        },
        {
            "type": "page-title-header"
        },
        {
            "type": "page-content"
        },
        {
            "type": "text"
        },
        {
            "type": "button"
        },
        {
            "type": "image"
        }
    ],
    "presets": [
        {
            "name": "Página principal",
            "blocks": {
                "page-wrapper": {
                    "type": "layout",
                    "settings": {
                        "image_desktop": "",
                        "background_color_desktop": "",
                        "css_styles_desktop": "display: flex; flex-direction: column; gap: 24px;",
                        "image_tablet": "",
                        "background_color_tablet": "",
                        "css_styles_tablet": "",
                        "image_mobile": "",
                        "background_color_mobile": "",
                        "css_styles_mobile": ""
                    },
                    "blocks": {
                        "title": {
                            "type": "page-title-header",
                            "settings": {},
                            "blocks": {
                                "page-heading": {
                                    "type": "text",
                                    "static": true,
                                    "settings": {
                                        "text": "",
                                        "text_type": "page_title",
                                        "color": "custom",
                                        "custom_color": "#000000",
                                        "bold": true,
                                        "italic": false,
                                        "underline": false,
                                        "line_through": false,
                                        "size_desktop": "4xl",
                                        "size_tablet": "",
                                        "size_mobile": "",
                                        "css_styles_desktop": "",
                                        "css_styles_tablet": "",
                                        "css_styles_mobile": ""
                                    },
                                    "blocks": {}
                                }
                            },
                            "block_order": [
                                "page-heading"
                            ]
                        },
                        "content": {
                            "type": "page-content",
                            "settings": {}
                        }
                    },
                    "block_order": [
                        "title",
                        "content"
                    ]
                }
            },
            "block_order": [
                "page-wrapper"
            ]
        }
    ]
}
{% endschema %}
