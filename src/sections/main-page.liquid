<section class="tiendu-main-page" style="padding: 48px 0;">
    <div style="padding: 0 8px;">
        <div style="max-width: 1024px; margin: 0 auto;">
            {% if section.blocks and section.blocks.size > 0 %}
                {% content_for 'blocks' %}
            {% elsif design_mode or preview_mode %}
                <div>Agrega bloques para construir la página.</div>
            {% endif %}
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Página principal",
    "enabled_on": {
        "templates": [
            "page"
        ]
    },
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "layout"
        },
        {
            "type": "page-title-header"
        },
        {
            "type": "page-content"
        },
        {
            "type": "text"
        },
        {
            "type": "button"
        },
        {
            "type": "image"
        }
    ],
    "presets": [
        {
            "name": "Página principal",
            "blocks": {
                "page-wrapper": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "display: flex; flex-direction: column; gap: 24px;"
                    },
                    "blocks": {
                        "title": {
                            "type": "page-title-header",
                            "blocks": {
                                "page-heading": {
                                    "type": "text",
                                    "static": true,
                                    "settings": {
                                        "text_type": "page_title",
                                        "custom_color": "#000000",
                                        "bold": true,
                                        "size_desktop": "4xl"
                                    }
                                }
                            },
                            "block_order": [
                                "page-heading"
                            ]
                        },
                        "content": {
                            "type": "page-content"
                        }
                    },
                    "block_order": [
                        "title",
                        "content"
                    ]
                }
            },
            "block_order": [
                "page-wrapper"
            ]
        }
    ]
}
{% endschema %}
