<style>
    .tiendu-side-menu {
        position: fixed;
        inset: 0;
        z-index: 9998;
        visibility: hidden;
        pointer-events: none;
        overflow: hidden;
    }

    .tiendu-side-menu[data-open='true'] {
        visibility: visible;
        pointer-events: auto;
    }

    .tiendu-side-menu[data-closing='true'] {
        visibility: visible;
        pointer-events: none;
    }

    .tiendu-side-menu__backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.28);
        opacity: 0;
        transition: opacity 0.24s ease;
    }

    .tiendu-side-menu__panel {
        position: relative;
        z-index: 1;
        width: min(28rem, calc(100vw - 2rem));
        height: 100%;
        max-width: 100%;
        background: white;
        overflow-y: auto;
        overflow-x: hidden;
        box-shadow: 0 0 24px rgba(0, 0, 0, 0.12);
        transform: translateX(calc(-100% - 1rem));
        transition: transform 0.28s ease;
        will-change: transform;
    }

    .tiendu-side-menu[data-open='true'] .tiendu-side-menu__backdrop {
        opacity: 1;
    }

    .tiendu-side-menu[data-open='true'] .tiendu-side-menu__panel {
        transform: translateX(0);
    }

    body.tiendu-side-menu-open {
        overflow: hidden;
    }

    @media (width <= 48rem) {
        .tiendu-side-menu__panel {
            width: min(24rem, calc(100vw - 1rem));
        }
    }
</style>

{% if design_mode or preview_mode %}
    <style>
        #side-menu-{{ section.id }} {
            position: relative;
            visibility: visible;
            pointer-events: auto;
            z-index: auto;
            overflow: visible;
        }
        #side-menu-{{ section.id }} .tiendu-side-menu__backdrop {
            display: none;
        }
        #side-menu-{{ section.id }} .tiendu-side-menu__panel {
            transform: none;
            width: 100%;
            max-width: 28rem;
            box-shadow: none;
            border: 1px dashed rgba(0, 0, 0, 0.2);
        }
    </style>
{% endif %}

<section id="side-menu-{{ section.id }}" class="tiendu-side-menu" data-side-menu-root data-open="{% if design_mode or preview_mode %}true{% else %}false{% endif %}" aria-hidden="{% if design_mode or preview_mode %}false{% else %}true{% endif %}">
    <button type="button" class="tiendu-side-menu__backdrop" data-side-menu-close aria-label="Cerrar menú"></button>
    <div class="tiendu-side-menu__panel">
        {% content_for 'blocks' %}
    </div>
</section>

