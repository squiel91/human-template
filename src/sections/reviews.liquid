<section class="tiendu-reviews" style="padding: 64px 0;">
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Add blocks to build the reviews section.</div>
    {% endif %}
</section>

{% schema %}
{
    "name": "Reviews",
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Reviews",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 0 var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: var(--container-max-width, 1024px); margin: 0 auto; display: flex; flex-direction: column; gap: 40px;",
                                "css_styles_tablet": "gap: 32px;",
                                "css_styles_mobile": "gap: 24px;"
                            },
                            "blocks": {
                                "layout_header": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap;",
                                        "css_styles_mobile": "flex-direction: column; align-items: flex-start;"
                                    },
                                    "blocks": {
                                        "layout_header_left": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex; flex-direction: column; gap: 8px;"
                                            },
                                            "blocks": {
                                                "label": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "OPINIONES",
                                                        "custom_color": "#666666",
                                                        "size_desktop": "sm",
                                                        "css_styles_desktop": "letter-spacing: 0.1em; text-transform: uppercase;"
                                                    }
                                                },
                                                "heading": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Lo que dicen nuestros clientes.",
                                                        "text_type": "section_title",
                                                        "bold": true,
                                                        "size_desktop": "4xl"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "label",
                                                "heading"
                                            ]
                                        },
                                        "layout_header_right": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex; flex-direction: column; align-items: flex-end; gap: 4px;",
                                                "css_styles_mobile": "align-items: flex-start;"
                                            },
                                            "blocks": {
                                                "aggregate_rating": {
                                                    "type": "layout",
                                                    "settings": {
                                                        "css_styles_desktop": "display: flex; align-items: center; gap: 12px;"
                                                    },
                                                    "blocks": {
                                                        "stars": {
                                                            "type": "stars",
                                                            "settings": {
                                                                "rating": 4.9,
                                                                "size": "lg"
                                                            }
                                                        },
                                                        "rating_text": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "4.9 / 5",
                                                                "bold": true
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "stars",
                                                        "rating_text"
                                                    ]
                                                },
                                                "reviews_count": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Sobre 3.400 reseñas",
                                                        "custom_color": "#666666",
                                                        "size_desktop": "sm"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "aggregate_rating",
                                                "reviews_count"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "layout_header_left",
                                        "layout_header_right"
                                    ]
                                },
                                "layout_grid": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;",
                                        "css_styles_tablet": "grid-template-columns: repeat(2, 1fr);",
                                        "css_styles_mobile": "grid-template-columns: 1fr;"
                                    },
                                    "blocks": {
                                        "review_1": {
                                            "type": "review",
                                            "blocks": {
                                                "layout_review": {
                                                    "type": "layout",
                                                    "settings": {
                                                        "css_styles_desktop": "display: flex; flex-direction: column; gap: 16px; padding: 24px; border: 1px solid #cccccc; border-radius: 0.375rem; background-color: #ffffff;",
                                                        "css_styles_tablet": "padding: 20px;",
                                                        "css_styles_mobile": "padding: 16px;"
                                                    },
                                                    "blocks": {
                                                        "stars": {
                                                            "type": "stars",
                                                            "settings": {
                                                                "rating": 5
                                                            }
                                                        },
                                                        "quote": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "\"Cambiar el tema fue muy simple y nuestra tienda se ve mucho más profesional.\"",
                                                                "text_type": "paragraph",
                                                                "css_styles_desktop": "font-size: 1.125rem; line-height: 1.6; margin: 0;"
                                                            }
                                                        },
                                                        "author": {
                                                            "type": "layout",
                                                            "settings": {
                                                                "css_styles_desktop": "display: flex; flex-direction: column; gap: 4px;"
                                                            },
                                                            "blocks": {
                                                                "author_name": {
                                                                    "type": "text",
                                                                    "settings": {
                                                                        "text": "Sofía P.",
                                                                        "bold": true,
                                                                        "css_styles_desktop": "font-size: 0.9375rem;"
                                                                    }
                                                                },
                                                                "author_role": {
                                                                    "type": "text",
                                                                    "settings": {
                                                                        "text": "Dueña, Estudio Verde",
                                                                        "size_desktop": "sm",
                                                                        "css_styles_desktop": "opacity: 0.7;"
                                                                    }
                                                                }
                                                            },
                                                            "block_order": [
                                                                "author_name",
                                                                "author_role"
                                                            ]
                                                        }
                                                    },
                                                    "block_order": [
                                                        "stars",
                                                        "quote",
                                                        "author"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "layout_review"
                                            ]
                                        },
                                        "review_2": {
                                            "type": "review",
                                            "blocks": {
                                                "layout_review": {
                                                    "type": "layout",
                                                    "settings": {
                                                        "css_styles_desktop": "display: flex; flex-direction: column; gap: 16px; padding: 24px; border: 1px solid #cccccc; border-radius: 0.375rem; background-color: #ffffff;",
                                                        "css_styles_tablet": "padding: 20px;",
                                                        "css_styles_mobile": "padding: 16px;"
                                                    },
                                                    "blocks": {
                                                        "stars": {
                                                            "type": "stars",
                                                            "settings": {
                                                                "rating": 5
                                                            }
                                                        },
                                                        "quote": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "\"Lo que más me gustó es que destaca los productos sin distraer al cliente.\"",
                                                                "text_type": "paragraph",
                                                                "css_styles_desktop": "font-size: 1.125rem; line-height: 1.6; margin: 0;"
                                                            }
                                                        },
                                                        "author": {
                                                            "type": "layout",
                                                            "settings": {
                                                                "css_styles_desktop": "display: flex; flex-direction: column; gap: 4px;"
                                                            },
                                                            "blocks": {
                                                                "author_name": {
                                                                    "type": "text",
                                                                    "settings": {
                                                                        "text": "Mateo L.",
                                                                        "bold": true,
                                                                        "css_styles_desktop": "font-size: 0.9375rem;"
                                                                    }
                                                                },
                                                                "author_role": {
                                                                    "type": "text",
                                                                    "settings": {
                                                                        "text": "Fundador, Taller 19",
                                                                        "size_desktop": "sm",
                                                                        "css_styles_desktop": "opacity: 0.7;"
                                                                    }
                                                                }
                                                            },
                                                            "block_order": [
                                                                "author_name",
                                                                "author_role"
                                                            ]
                                                        }
                                                    },
                                                    "block_order": [
                                                        "stars",
                                                        "quote",
                                                        "author"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "layout_review"
                                            ]
                                        },
                                        "review_3": {
                                            "type": "review",
                                            "blocks": {
                                                "layout_review": {
                                                    "type": "layout",
                                                    "settings": {
                                                        "css_styles_desktop": "display: flex; flex-direction: column; gap: 16px; padding: 24px; border: 1px solid #cccccc; border-radius: 0.375rem; background-color: #ffffff;",
                                                        "css_styles_tablet": "padding: 20px;",
                                                        "css_styles_mobile": "padding: 16px;"
                                                    },
                                                    "blocks": {
                                                        "stars": {
                                                            "type": "stars",
                                                            "settings": {
                                                                "rating": 5
                                                            }
                                                        },
                                                        "quote": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "\"Desde que lo instalamos, las conversiones subieron y el rebote bajó.\"",
                                                                "text_type": "paragraph",
                                                                "css_styles_desktop": "font-size: 1.125rem; line-height: 1.6; margin: 0;"
                                                            }
                                                        },
                                                        "author": {
                                                            "type": "layout",
                                                            "settings": {
                                                                "css_styles_desktop": "display: flex; flex-direction: column; gap: 4px;"
                                                            },
                                                            "blocks": {
                                                                "author_name": {
                                                                    "type": "text",
                                                                    "settings": {
                                                                        "text": "Camila D.",
                                                                        "bold": true,
                                                                        "css_styles_desktop": "font-size: 0.9375rem;"
                                                                    }
                                                                },
                                                                "author_role": {
                                                                    "type": "text",
                                                                    "settings": {
                                                                        "text": "Ecommerce, La Casa",
                                                                        "size_desktop": "sm",
                                                                        "css_styles_desktop": "opacity: 0.7;"
                                                                    }
                                                                }
                                                            },
                                                            "block_order": [
                                                                "author_name",
                                                                "author_role"
                                                            ]
                                                        }
                                                    },
                                                    "block_order": [
                                                        "stars",
                                                        "quote",
                                                        "author"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "layout_review"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "review_1",
                                        "review_2",
                                        "review_3"
                                    ]
                                }
                            },
                            "block_order": [
                                "layout_header",
                                "layout_grid"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
