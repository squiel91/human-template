<section class="tiendu-main-product" data-product-root>
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Add blocks to build the product page.</div>
    {% endif %}

    <script id="product-json" type="application/json">{{ product | json }}</script>
</section>

{% schema %}
{
    "name": "Main product",
    "enabled_on": {
        "templates": [
            "product"
        ]
    },
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Main product",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 64px var(--container-horizontal-padding, 8px);",
                        "css_styles_tablet": "padding: 40px var(--container-horizontal-padding, 8px);",
                        "css_styles_mobile": "padding: 32px var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: var(--container-max-width, 1024px); margin: 0 auto; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 40px;",
                                "css_styles_tablet": "grid-template-columns: 1fr; gap: 28px;",
                                "css_styles_mobile": "grid-template-columns: 1fr; gap: 24px;"
                            },
                            "blocks": {
                                "gallery": {
                                    "type": "product__gallery",
                                    "settings": {
                                        "show_thumbnails": "desktop",
                                        "show_arrows": true,
                                        "main_rounding": "theme",
                                        "thumbnail_rounding": "theme"
                                    }
                                },
                                "content_column": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: flex; flex-direction: column; gap: 16px; justify-content: flex-start;"
                                    },
                                    "blocks": {
                                        "title": {
                                            "type": "product__title",
                                            "blocks": {
                                                "default-text": {
                                                    "type": "text",
                                                    "static": true,
                                                    "settings": {
                                                        "text_type": "page_title",
                                                        "bold": true,
                                                        "size_desktop": "4xl",
                                                        "size_tablet": "3xl",
                                                        "size_mobile": "2xl"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "default-text"
                                            ]
                                        },
                                        "reviews": {
                                            "type": "product__reviews",
                                            "blocks": {
                                                "default-stars": {
                                                    "type": "stars",
                                                    "static": true,
                                                    "settings": {
                                                        "size": "lg",
                                                        "show_value_and_quantity": true
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "default-stars"
                                            ]
                                        },
                                        "pricing_row": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex; align-items: center; gap: 12px; flex-wrap: wrap;"
                                            },
                                            "blocks": {
                                                "price": {
                                                    "type": "product__price",
                                                    "blocks": {
                                                        "default-text": {
                                                            "type": "text",
                                                            "static": true,
                                                            "settings": {
                                                                "bold": true,
                                                                "size_desktop": "2xl"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "default-text"
                                                    ]
                                                },
                                                "compare_price": {
                                                    "type": "product__compare-price",
                                                    "blocks": {
                                                        "default-text": {
                                                            "type": "text",
                                                            "static": true,
                                                            "settings": {
                                                                "custom_color": "#94a3b8",
                                                                "line_through": true,
                                                                "size_desktop": "2xl"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "default-text"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "price",
                                                "compare_price"
                                            ]
                                        },
                                        "add_to_cart": {
                                            "type": "button",
                                            "preset": "primary",
                                            "settings": {
                                                "action": "add_to_cart"
                                            },
                                            "blocks": {
                                                "icon": {
                                                    "type": "icon",
                                                    "settings": {
                                                        "icon": "plus",
                                                        "size": "md",
                                                        "stroke_width": "2"
                                                    }
                                                },
                                                "text": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Agregar al carrito"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "icon",
                                                "text"
                                            ]
                                        },
                                        "share": {
                                            "type": "button",
                                            "preset": "secondary",
                                            "settings": {
                                                "action": "share"
                                            },
                                            "blocks": {
                                                "text": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Compartir"
                                                    }
                                                },
                                                "icon": {
                                                    "type": "icon",
                                                    "settings": {
                                                        "icon": "forward",
                                                        "size": "md",
                                                        "stroke_width": "2"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "text",
                                                "icon"
                                            ]
                                        },
                                        "selectors": {
                                            "type": "product__attribute-selectors"
                                        },
                                        "quantity": {
                                            "type": "product__quantity",
                                            "settings": {
                                                "label": "Cantidad",
                                                "rounding": "theme"
                                            }
                                        }
                                    },
                                    "block_order": [
                                        "title",
                                        "reviews",
                                        "pricing_row",
                                        "selectors",
                                        "quantity",
                                        "add_to_cart",
                                        "share"
                                    ]
                                }
                            },
                            "block_order": [
                                "gallery",
                                "content_column"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
