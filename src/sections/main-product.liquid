<section class="t-main-product" data-product-root>
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Add blocks to build the product page.</div>
    {% endif %}

    <script id="product-json" type="application/json">{{ product | json }}</script>
</section>

{% schema %}
{
    "name": "Main product",
    "enabled_on": {
        "templates": [
            "product"
        ]
    },
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Main product",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 64px var(--container-horizontal-padding, 8px);",
                        "css_styles_tablet": "padding: 40px var(--container-horizontal-padding, 8px);",
                        "css_styles_mobile": "padding: 32px var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: var(--container-max-width, 1024px); margin: 0 auto; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 40px;",
                                "css_styles_tablet": "grid-template-columns: 1fr; gap: 28px;",
                                "css_styles_mobile": "grid-template-columns: 1fr; gap: 24px;"
                            },
                            "blocks": {
                                "gallery": {
                                    "type": "product__gallery",
                                    "settings": {
                                        "show_thumbnails": "desktop",
                                        "show_arrows": true,
                                        "main_rounding": "theme",
                                        "thumbnail_rounding": "theme"
                                    }
                                },
                                "content_column": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: flex; flex-direction: column; gap: 16px; justify-content: flex-start;"
                                    },
                                    "blocks": {
                                        "title": {
                                            "type": "product__title",
                                            "blocks": {
                                                "default-text": {
                                                    "type": "text",
                                                    "static": true,
                                                    "settings": {
                                                        "text_type": "page_title",
                                                        "size_desktop": "4xl",
                                                        "size_tablet": "3xl",
                                                        "size_mobile": "2xl"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "default-text"
                                            ]
                                        },
                                        "stock_status": {
                                            "type": "product__stock-status"
                                        },
                                        "units_sold": {
                                            "type": "product__units-sold"
                                        },
                                        "reviews": {
                                            "type": "product__reviews",
                                            "blocks": {
                                                "default-stars": {
                                                    "type": "stars",
                                                    "static": true,
                                                    "settings": {
                                                        "size": "lg",
                                                        "show_value_and_quantity": true
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "default-stars"
                                            ]
                                        },
                                        "pricing_row": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex; align-items: center; gap: 12px; flex-wrap: wrap;"
                                            },
                                            "blocks": {
                                                "price": {
                                                    "type": "product__price",
                                                    "blocks": {
                                                        "default-text": {
                                                            "type": "text",
                                                            "static": true,
                                                            "settings": {
                                                                "font_weight": "700",
                                                                "size_desktop": "2xl"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "default-text"
                                                    ]
                                                },
                                                "compare_price": {
                                                    "type": "product__compare-price",
                                                    "blocks": {
                                                        "default-text": {
                                                            "type": "text",
                                                            "static": true,
                                                            "settings": {
                                                                "custom_color": "#94a3b8",
                                                                "line_through": true,
                                                                "size_desktop": "2xl"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "default-text"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "price",
                                                "compare_price"
                                            ]
                                        },
                                        "quantity_cart_row": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex; align-items: center; gap: 12px; flex-wrap: wrap;"
                                            },
                                            "blocks": {
                                                "quantity": {
                                                    "type": "product__quantity",
                                                    "settings": {
                                                        "label": "Cantidad",
                                                        "rounding": "theme"
                                                    }
                                                },
                                                "add_to_cart": {
                                                    "type": "button",
                                                    "preset": "primary",
                                                    "settings": {
                                                        "action": "add_to_cart",
                                                        "css_styles_desktop": "position: relative;\ndisplay: flex;\nalign-items: center;\njustify-content: center;\ngap: 8px;\ntext-decoration: none;\ncursor: pointer;\nborder: none;\nfont-family: inherit;\nline-height: 1;\npadding: 0.75rem 1.125rem;\nfont-size: 1rem;\nborder-radius: var(--button-input-border-radius, 0.375rem);\nbackground-color: var(--primary-color);\ncolor: white;\ntransition: opacity 0.2s ease;\n&:hover { opacity: 0.9; }\n&:disabled { opacity: 0.7; cursor: wait; }\nflex-grow: 1;"
                                                    },
                                                    "blocks": {
                                                        "icon": {
                                                            "type": "icon",
                                                            "settings": {
                                                                "icon": "plus",
                                                                "size": "md",
                                                                "stroke_width": "2"
                                                            }
                                                        },
                                                        "text": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "Agregar al carrito"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "icon",
                                                        "text"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "quantity",
                                                "add_to_cart"
                                            ]
                                        },
                                        "share": {
                                            "type": "button",
                                            "preset": "secondary",
                                            "settings": {
                                                "action": "share",
                                                "css_styles_desktop": "position: relative;\ndisplay: flex;\nalign-items: center;\njustify-content: center;\ngap: 8px;\ntext-decoration: none;\ncursor: pointer;\nborder: none;\nfont-family: inherit;\nline-height: 1;\npadding: 0.75rem 1.125rem;\nfont-size: 1rem;\nborder-radius: var(--button-input-border-radius, 0.375rem);\nbackground-color: transparent;\ncolor: var(--primary-color);\ntransition: background-color 0.2s ease;\n&:hover { background-color: rgba(0, 0, 0, 0.06); }\n&:disabled { opacity: 0.7; cursor: wait; }\nalign-self: flex-start;"
                                            },
                                            "blocks": {
                                                "icon": {
                                                    "type": "icon",
                                                    "settings": {
                                                        "icon": "forward",
                                                        "size": "md",
                                                        "stroke_width": "2"
                                                    }
                                                },
                                                "text": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Compartir"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "icon",
                                                "text"
                                            ]
                                        },
                                        "purchase_benefits": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: grid; grid-template-columns: min-content 1fr; column-gap: 12px; row-gap: 10px; align-items: center;",
                                                "css_styles_mobile": "column-gap: 10px; row-gap: 8px;"
                                            },
                                            "blocks": {
                                                "shipping_icon": {
                                                    "type": "icon",
                                                    "settings": {
                                                        "icon": "truck",
                                                        "color": "custom",
                                                        "custom_color": "#6b7280",
                                                        "size": "sm",
                                                        "stroke_width": "2"
                                                    }
                                                },
                                                "shipping_text": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Envío gratis en pedidos superiores a $ 2.000",
                                                        "text_type": "paragraph",
                                                        "size_desktop": "sm",
                                                        "custom_color": "#6b7280"
                                                    }
                                                },
                                                "bank_transfer_icon": {
                                                    "type": "icon",
                                                    "settings": {
                                                        "icon": "piggy-bank",
                                                        "color": "custom",
                                                        "custom_color": "#6b7280",
                                                        "size": "sm",
                                                        "stroke_width": "2"
                                                    }
                                                },
                                                "bank_transfer_text": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "10% OFF con transferencia bancaria",
                                                        "text_type": "paragraph",
                                                        "size_desktop": "sm",
                                                        "custom_color": "#6b7280"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "bank_transfer_icon",
                                                "bank_transfer_text",
                                                "shipping_icon",
                                                "shipping_text"
                                            ]
                                        },
                                        "selectors": {
                                            "type": "product__attribute-selectors"
                                        }
                                    },
                                    "block_order": [
                                        "title",
                                        "units_sold",
                                        "reviews",
                                        "pricing_row",
                                        "selectors",
                                        "stock_status",
                                        "quantity_cart_row",
                                        "purchase_benefits",
                                        "share"
                                    ]
                                }
                            },
                            "block_order": [
                                "gallery",
                                "content_column"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
