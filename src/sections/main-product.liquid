<section class="tiendu-main-product" data-product-root style="padding: 32px 0;">
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Agrega bloques para construir la página de producto.</div>
    {% endif %}

    <script id="product-json" type="application/json">{{ product | json }}</script>
</section>

{% schema %}
{
    "name": "Producto principal",
    "enabled_on": {
        "templates": [
            "product"
        ]
    },
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Producto principal",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 0 var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: var(--container-max-width, 1024px); margin: 0 auto; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 40px;",
                                "css_styles_tablet": "grid-template-columns: 1fr; gap: 28px;",
                                "css_styles_mobile": "grid-template-columns: 1fr; gap: 24px;"
                            },
                            "blocks": {
                                "gallery": {
                                    "type": "product__gallery"
                                },
                                "content_column": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: flex; flex-direction: column; gap: 16px; justify-content: flex-start;"
                                    },
                                    "blocks": {
                                        "title": {
                                            "type": "product__title",
                                            "blocks": {
                                                "default-text": {
                                                    "type": "text",
                                                    "static": true,
                                                    "settings": {
                                                        "text_type": "page_title",
                                                        "custom_color": "#000000",
                                                        "bold": true,
                                                        "size_desktop": "4xl"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "default-text"
                                            ]
                                        },
                                        "pricing_row": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex; align-items: center; gap: 12px; flex-wrap: wrap;"
                                            },
                                            "blocks": {
                                                "price": {
                                                    "type": "product__price",
                                                    "blocks": {
                                                        "default-text": {
                                                            "type": "text",
                                                            "static": true,
                                                            "settings": {
                                                                "custom_color": "#000000",
                                                                "bold": true,
                                                                "size_desktop": "2xl"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "default-text"
                                                    ]
                                                },
                                                "compare_price": {
                                                    "type": "product__compare-price",
                                                    "blocks": {
                                                        "default-text": {
                                                            "type": "text",
                                                            "static": true,
                                                            "settings": {
                                                                "custom_color": "#94a3b8",
                                                                "line_through": true,
                                                                "size_desktop": "2xl"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "default-text"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "price",
                                                "compare_price"
                                            ]
                                        },
                                        "add_to_cart": {
                                            "type": "button",
                                            "settings": {
                                                "text": "Agregar al carrito",
                                                "action": "add_to_cart",
                                                "icon_position": "before",
                                                "rounding": "theme",
                                                "css_styles_desktop": "width: 100%; margin-top: 8px;"
                                            },
                                            "blocks": {
                                                "icon": {
                                                    "type": "icon",
                                                    "settings": {
                                                        "icon": "plus",
                                                        "color": "custom",
                                                        "custom_color": "#ffffff",
                                                        "size": "md",
                                                        "stroke_width": "2"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "icon"
                                            ]
                                        },
                                        "share": {
                                            "type": "product__share",
                                            "blocks": {
                                                "share-button": {
                                                    "type": "button",
                                                    "static": true,
                                                    "settings": {
                                                        "text": "",
                                                        "action": "share",
                                                        "variant": "secondary",
                                                        "rounding": "theme",
                                                        "css_styles_desktop": "width: 100%;"
                                                    },
                                                    "blocks": {
                                                        "icon": {
                                                            "type": "icon",
                                                            "settings": {
                                                                "icon": "forward",
                                                                "color": "custom",
                                                                "custom_color": "#000000",
                                                                "size": "md",
                                                                "stroke_width": "2"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "icon"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "share-button"
                                            ]
                                        },
                                        "selectors": {
                                            "type": "product__attribute-selectors"
                                        }
                                    },
                                    "block_order": [
                                        "title",
                                        "pricing_row",
                                        "selectors",
                                        "add_to_cart",
                                        "share"
                                    ]
                                }
                            },
                            "block_order": [
                                "gallery",
                                "content_column"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
