<nav class="header-nav" aria-label="Navegacion principal"{% if section.settings.sticky_header %} data-header-sticky-root style="position: sticky; top: 0; z-index: 30; width: 100%; background-color: {{ settings.background_color | default: 'white' }};"{% endif %}>
    {% content_for "blocks" %}
</nav>

{% schema %}
{
    "name": "Header",
    "max_blocks": 1,
    "settings": [
        {
            "type": "checkbox",
            "id": "sticky_header",
            "label": "Fijar arriba",
            "default": true
        }
    ],
    "blocks": [
        {
            "type": "@theme"
        }
    ],
    "presets": [
        {
            "name": "Minimalista",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 0 var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: var(--container-max-width, 1024px);\nmargin: 0 auto;\ndisplay: flex;\nflex-direction: column;\ngap: 20px;\npadding: 24px 0;",
                                "css_styles_tablet": "gap: 16px;\npadding: 20px 0;",
                                "css_styles_mobile": "gap: 12px;\npadding: 16px 0;"
                            },
                            "blocks": {
                                "layout_topbar": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: flex;\nalign-items: center;\njustify-content: space-between;\ngap: 24px;",
                                        "css_styles_mobile": "gap: 12px;"
                                    },
                                    "blocks": {
                                        "layout_left": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex;\nalign-items: center;\ngap: 14px;",
                                                "css_styles_mobile": "gap: 12px;"
                                            },
                                            "blocks": {
                                                "button_menu": {
                                                    "type": "button",
                                                    "settings": {
                                                        "text": "",
                                                        "action": "menu",
                                                        "variant": "secondary",
                                                        "rounding": "theme"
                                                    },
                                                    "blocks": {
                                                        "icon": {
                                                            "type": "icon",
                                                            "settings": {
                                                                "icon": "text-align-start",
                                                                "color": "custom",
                                                                "custom_color": "#000000",
                                                                "size": "md",
                                                                "stroke_width": "2"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "icon"
                                                    ]
                                                },
                                                "link_brand": {
                                                    "type": "link",
                                                    "settings": {
                                                        "url": "/"
                                                    },
                                                    "blocks": {
                                                        "text": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "Tu negocio",
                                                                "custom_color": "#000000",
                                                                "bold": true,
                                                                "size_desktop": "base"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "text"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "button_menu",
                                                "link_brand"
                                            ]
                                        },
                                        "layout_right": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex;\nalign-items: center;\ngap: 14px;",
                                                "css_styles_mobile": "gap: 12px;"
                                            },
                                            "blocks": {
                                                "button_search": {
                                                    "type": "button",
                                                    "settings": {
                                                        "text": "",
                                                        "action": "search",
                                                        "variant": "secondary",
                                                        "rounding": "theme",
                                                        "css_styles_desktop": "color: #000000;"
                                                    },
                                                    "blocks": {
                                                        "icon": {
                                                            "type": "icon",
                                                            "settings": {
                                                                "icon": "search",
                                                                "color": "custom",
                                                                "custom_color": "#000000",
                                                                "size": "md",
                                                                "stroke_width": "2"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "icon"
                                                    ]
                                                },
                                                "button_cart": {
                                                    "type": "button",
                                                    "settings": {
                                                        "text": "",
                                                        "action": "cart",
                                                        "variant": "secondary",
                                                        "rounding": "theme",
                                                        "css_styles_desktop": "color: #000000; position: relative;"
                                                    },
                                                    "blocks": {
                                                        "icon": {
                                                            "type": "icon",
                                                            "settings": {
                                                                "icon": "shopping-bag",
                                                                "color": "custom",
                                                                "custom_color": "#000000",
                                                                "size": "md",
                                                                "stroke_width": "2"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "icon"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "button_search",
                                                "button_cart"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "layout_left",
                                        "layout_right"
                                    ]
                                },
                                "layout_nav": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: flex;\nalign-items: center;\ngap: 24px;",
                                        "css_styles_tablet": "display: none;",
                                        "css_styles_mobile": "display: none;"
                                    },
                                    "blocks": {
                                        "link_products": {
                                            "type": "link",
                                            "settings": {
                                                "url": ""
                                            },
                                            "blocks": {
                                                "text": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Productos",
                                                        "custom_color": "#000000",
                                                        "italic": true,
                                                        "size_desktop": "sm"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "text"
                                            ]
                                        },
                                        "link_offers": {
                                            "type": "link",
                                            "settings": {
                                                "url": ""
                                            },
                                            "blocks": {
                                                "text": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Ofertas",
                                                        "custom_color": "#000000",
                                                        "italic": true,
                                                        "size_desktop": "sm"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "text"
                                            ]
                                        },
                                        "link_categories": {
                                            "type": "link",
                                            "settings": {
                                                "url": ""
                                            },
                                            "blocks": {
                                                "text": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Categorias",
                                                        "custom_color": "#000000",
                                                        "italic": true,
                                                        "size_desktop": "sm"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "text"
                                            ]
                                        },
                                        "link_blog": {
                                            "type": "link",
                                            "settings": {
                                                "url": ""
                                            },
                                            "blocks": {
                                                "text": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Blog",
                                                        "custom_color": "#000000",
                                                        "italic": true,
                                                        "size_desktop": "sm"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "text"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "link_products",
                                        "link_offers",
                                        "link_categories",
                                        "link_blog"
                                    ]
                                }
                            },
                            "block_order": [
                                "layout_topbar",
                                "layout_nav"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
