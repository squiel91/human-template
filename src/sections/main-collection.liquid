<section class="tiendu-main-collection" style="padding: 32px 0;">
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Add blocks to build the collection page.</div>
    {% endif %}
</section>

{% schema %}
{
    "name": "Main collection",
    "enabled_on": {
        "templates": [
            "collection"
        ]
    },
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Main collection",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 0 var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: var(--container-max-width, 1024px); margin: 0 auto; display: flex; flex-direction: column; gap: 32px;",
                                "css_styles_tablet": "gap: 24px;",
                                "css_styles_mobile": "gap: 20px;"
                            },
                            "blocks": {
                                "title": {
                                    "type": "_text-for-featured-collection",
                                    "blocks": {
                                        "default-text": {
                                            "type": "text",
                                            "static": true,
                                            "settings": {
                                                "text_type": "page_title",
                                                "vertical_margin": "default",
                                                "bold": true,
                                                "size_desktop": "5xl"
                                            }
                                        }
                                    },
                                    "block_order": [
                                        "default-text"
                                    ]
                                },
                                "layout_grid": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 24px;",
                                        "css_styles_tablet": "grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;",
                                        "css_styles_mobile": "grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px;"
                                    },
                                    "blocks": {
                                        "products": {
                                            "type": "collection-products",
                                            "settings": {
                                                "products_per_page": 12,
                                                "show_pagination": true
                                            },
                                            "blocks": {
                                                "product_card": {
                                                    "type": "product",
                                                    "static": true,
                                                    "blocks": {
                                                        "card_wrap": {
                                                            "type": "layout",
                                                            "settings": {
                                                                "css_styles_desktop": "display: flex; flex-direction: column; gap: 8px;"
                                                            },
                                                            "blocks": {
                                                                "card_image": {
                                                                    "type": "product__image",
                                                                    "settings": {
                                                                        "transition_to_second_image": true
                                                                    },
                                                                    "blocks": {
                                                                        "default-image": {
                                                                            "type": "image",
                                                                            "static": true,
                                                                            "settings": {
                                                                                "size": "full",
                                                                                "image_ratio": "product_default",
                                                                                "rounding": "theme"
                                                                            }
                                                                        }
                                                                    },
                                                                    "block_order": [
                                                                        "default-image"
                                                                    ]
                                                                },
                                                                "card_title": {
                                                                    "type": "product__title",
                                                                    "blocks": {
                                                                        "default-text": {
                                                                            "type": "text",
                                                                            "static": true,
                                                                            "settings": {
                                                                            }
                                                                        }
                                                                    },
                                                                    "block_order": [
                                                                        "default-text"
                                                                    ]
                                                                },
                                                                "card_pricing": {
                                                                    "type": "layout",
                                                                    "settings": {
                                                                        "css_styles_desktop": "display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;"
                                                                    },
                                                                    "blocks": {
                                                                        "card_price": {
                                                                            "type": "product__price",
                                                                            "blocks": {
                                                                                "default-text": {
                                                                                    "type": "text",
                                                                                    "static": true,
                                                                                    "settings": {
                                                                                        "bold": true
                                                                                    }
                                                                                }
                                                                            },
                                                                            "block_order": [
                                                                                "default-text"
                                                                            ]
                                                                        },
                                                                        "card_compare_price": {
                                                                            "type": "product__compare-price",
                                                                            "blocks": {
                                                                                "default-text": {
                                                                                    "type": "text",
                                                                                    "static": true,
                                                                                    "settings": {
                                                                                        "custom_color": "#94a3b8",
                                                                                        "line_through": true
                                                                                    }
                                                                                }
                                                                            },
                                                                            "block_order": [
                                                                                "default-text"
                                                                            ]
                                                                        }
                                                                    },
                                                                    "block_order": [
                                                                        "card_price",
                                                                        "card_compare_price"
                                                                    ]
                                                                }
                                                            },
                                                            "block_order": [
                                                                "card_image",
                                                                "card_title",
                                                                "card_pricing"
                                                            ]
                                                        }
                                                    },
                                                    "block_order": [
                                                        "card_wrap"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "product_card"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "products"
                                    ]
                                }
                            },
                            "block_order": [
                                "title",
                                "layout_grid"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
