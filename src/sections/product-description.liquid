<section class="tiendu-product-description" style="padding: 16px 0 32px;">
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Agrega bloques para construir la descripción.</div>
    {% endif %}
</section>

{% schema %}
{
    "name": "Descripción del producto",
    "enabled_on": {
        "templates": ["product"]
    },
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Descripción del producto",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "image_desktop": "",
                        "background_color_desktop": "",
                        "css_styles_desktop": "padding: 0 8px;",
                        "image_tablet": "",
                        "background_color_tablet": "",
                        "css_styles_tablet": "",
                        "image_mobile": "",
                        "background_color_mobile": "",
                        "css_styles_mobile": ""
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "image_desktop": "",
                                "background_color_desktop": "",
                                "css_styles_desktop": "max-width: 1024px; margin: 0 auto; display: flex; flex-direction: column; gap: 20px;",
                                "image_tablet": "",
                                "background_color_tablet": "",
                                "css_styles_tablet": "",
                                "image_mobile": "",
                                "background_color_mobile": "",
                                "css_styles_mobile": ""
                            },
                            "blocks": {
                                "title": {
                                    "type": "text",
                                    "settings": {
                                        "text": "Descripción",
                                        "text_type": "section_title",
                                        "color": "custom",
                                        "custom_color": "#000000",
                                        "bold": true,
                                        "italic": false,
                                        "underline": false,
                                        "line_through": false,
                                        "size_desktop": "2xl",
                                        "size_tablet": "",
                                        "size_mobile": "",
                                        "css_styles_desktop": "",
                                        "css_styles_tablet": "",
                                        "css_styles_mobile": ""
                                    },
                                    "blocks": {}
                                },
                                "description": {
                                    "type": "product__description",
                                    "settings": {}
                                }
                            },
                            "block_order": [
                                "title",
                                "description"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
