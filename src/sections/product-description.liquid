{% assign product_obj = product %}
{% assign visible_specifications_count = 0 %}

{% if product_obj.specifications %}
    {% for specification in product_obj.specifications %}
        {% assign specification_name_first_character = specification.name | slice: 0, 1 %}
        {% if specification.name != blank and specification.value != blank and specification_name_first_character != '_' %}
            {% assign visible_specifications_count = visible_specifications_count | plus: 1 %}
        {% endif %}
    {% endfor %}
{% endif %}

{% if product_obj.description != blank or visible_specifications_count > 0 %}
    <section class="t-product-description"{% assign show_animation = settings.animations %}{% if section.settings.enter_animation == "yes" %}{% assign show_animation = true %}{% elsif section.settings.enter_animation == "no" %}{% assign show_animation = false %}{% endif %}{% if show_animation %} data-fly-in-intro{% endif %}>
        {% if section.blocks and section.blocks.size > 0 %}
            {% content_for 'blocks' %}
        {% endif %}
    </section>
{% endif %}

{% schema %}
{
    "name": "Product description",
    "enabled_on": {
        "templates": [
            "product"
        ]
    },
    "max_blocks": 1,
    "settings": [
        {
            "type": "select",
            "id": "enter_animation",
            "label": "Enter animation",
            "default": "theme_default",
            "options": [
                {
                    "value": "theme_default",
                    "label": "Theme default"
                },
                {
                    "value": "no",
                    "label": "No enter animation"
                },
                {
                    "value": "yes",
                    "label": "Enter animation"
                }
            ]
        }
    ],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Product description",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 64px var(--container-horizontal-padding, 8px);",
                        "css_styles_tablet": "padding: 40px var(--container-horizontal-padding, 8px);",
                        "css_styles_mobile": "padding: 32px var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: var(--container-max-width, 1024px); margin: 0 auto; display: flex; flex-direction: column; gap: 20px;"
                            },
                            "blocks": {
                                "title": {
                                    "type": "text",
                                    "settings": {
                                        "text": "Sobre el producto",
                                        "text_type": "section_title",
                                        "size_desktop": "2xl",
                                        "size_tablet": "xl",
                                        "size_mobile": "lg"
                                    }
                                },
                                "description": {
                                    "type": "product__description",
                                    "blocks": {
                                        "text": {
                                            "type": "text",
                                            "static": true,
                                            "settings": {
                                                "text_type": "paragraph",
                                                "css_styles_desktop": "line-height: 1.7; white-space: pre-line;"
                                            }
                                        }
                                    },
                                    "block_order": [
                                        "text"
                                    ]
                                },
                                "specifications": {
                                    "type": "product__specifications",
                                    "blocks": {
                                        "specification_row": {
                                            "type": "product__specification",
                                            "static": true
                                        }
                                    },
                                    "block_order": [
                                        "specification_row"
                                    ]
                                }
                            },
                            "block_order": [
                                "title",
                                "description",
                                "specifications"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
