{% assign popup_id = 'tiendu__newsletter-popup-' | append: section.id %}

<style>
    .t-popup-open {
        overflow: hidden;
    }

    #{{ popup_id }} {
        position: fixed;
        inset: 0;
        z-index: var(--z-popup, 60);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    #{{ popup_id }}[hidden] {
        display: none;
    }

    #{{ popup_id }} .t-newsletter-popup__overlay {
        position: absolute;
        inset: 0;
        background: rgba(17, 24, 39, 0.45);
    }

    #{{ popup_id }} .t-newsletter-popup__surface {
        position: relative;
        z-index: 1;
        width: min(100%, 28rem);
    }

    @media (width <= 48rem) {
        #{{ popup_id }} {
            padding: 16px;
        }

        #{{ popup_id }} .t-newsletter-popup__surface {
            width: 100%;
        }
    }
</style>

<section
    id="{{ popup_id }}"
    class="t-newsletter-popup"
    data-newsletter-popup-root
    data-popup-key="{{ section.settings.popup_key | escape }}"
    data-popup-delay-seconds="{{ section.settings.delay_seconds | default: 6 }}"
    data-popup-force-open="{% if design_mode or preview_mode %}true{% else %}false{% endif %}"
    hidden
    aria-hidden="true"
>
    <div class="t-newsletter-popup__overlay" aria-hidden="true"></div>

    <div class="t-newsletter-popup__surface" role="dialog" aria-modal="true" aria-label="Newsletter">
        {% if section.blocks and section.blocks.size > 0 %}
            {% content_for 'blocks' %}
        {% elsif design_mode or preview_mode %}
            <div>Add blocks to build the newsletter popup.</div>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Newsletter popup",
    "enabled_on": {
        "groups": [
            "footer"
        ]
    },
    "max_blocks": 1,
    "settings": [
        {
            "type": "range",
            "id": "delay_seconds",
            "label": "Show after",
            "min": 0,
            "max": 30,
            "step": 1,
            "unit": "s",
            "default": 6
        },
        {
            "type": "text",
            "id": "popup_key",
            "label": "Popup key",
            "info": "Change this key to show the popup again or use more than one version.",
            "default": "newsletter-popup"
        }
    ],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Newsletter popup",
            "blocks": {
                "popup_card": {
                    "type": "layout",
                    "settings": {
                        "background_color_desktop": "#000000",
                        "css_styles_desktop": "position: relative; display: flex; flex-direction: column; justify-content: flex-end; gap: 14px; min-height: 34rem; padding: 24px; overflow: hidden; border-radius: 1.5rem; box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4); background-position: center; background-size: cover; background-repeat: no-repeat; color: white;",
                        "css_styles_tablet": "min-height: 32rem;",
                        "css_styles_mobile": "min-height: 30rem; padding: 20px; border-radius: 1.25rem;"
                    },
                    "blocks": {
                        "close_x": {
                            "type": "button",
                            "preset": "icon",
                            "settings": {
                                "action": "close_popup",
                                "css_styles_desktop": "position: absolute; top: 16px; right: 16px; z-index: 10; color: white;"
                            },
                            "blocks": {
                                "icon": {
                                    "type": "icon",
                                    "settings": {
                                        "icon": "x",
                                        "size": "md",
                                        "stroke_width": "2.5"
                                    }
                                }
                            },
                            "block_order": [
                                "icon"
                            ]
                        },
                        "label": {
                            "type": "text",
                            "settings": {
                                "text": "NEWSLETTER",
                                "size_desktop": "sm",
                                "custom_color": "#f9fafb",
                                "css_styles_desktop": "letter-spacing: 0.12em;"
                            }
                        },
                        "heading": {
                            "type": "text",
                            "settings": {
                                "text": "Llevate un beneficio especial.",
                                "text_type": "section_title",
                                "size_desktop": "3xl",
                                "custom_color": "#ffffff",
                                "css_styles_desktop": "max-width: 12ch;"
                            }
                        },
                        "description": {
                            "type": "text",
                            "settings": {
                                "text": "Dejanos tu email y te mandamos el descuento para tu próximo pedido.",
                                "text_type": "paragraph",
                                "custom_color": "#f3f4f6",
                                "css_styles_desktop": "max-width: 32ch; line-height: 1.5;"
                            }
                        },
                        "form": {
                            "type": "newsletter-form",
                            "blocks": {
                                "form_layout": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: flex; flex-direction: column; gap: 10px; width: 100%; margin-top: 4px;"
                                    },
                                    "blocks": {
                                        "email_input": {
                                            "type": "input",
                                            "settings": {
                                                "rounding": "theme",
                                                "placeholder": "Ingresá tu email",
                                                "css_styles_desktop": "width: 100%;"
                                            }
                                        },
                                        "submit_button": {
                                            "type": "button",
                                            "preset": "primary",
                                            "settings": {
                                                "action": "submit"
                                            }
                                        }
                                    },
                                    "block_order": [
                                        "email_input",
                                        "submit_button"
                                    ]
                                }
                            },
                            "block_order": [
                                "form_layout"
                            ]
                        },
                        "dismiss_button": {
                            "type": "button",
                            "preset": "secondary",
                            "settings": {
                                "action": "close_popup"
                            }
                        }
                    },
                    "block_order": [
                        "close_x",
                        "label",
                        "heading",
                        "description",
                        "form",
                        "dismiss_button"
                    ]
                }
            },
            "block_order": [
                "popup_card"
            ]
        }
    ]
}
{% endschema %}
