<section class="tiendu-main-404">
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% else %}
        <div class="tiendu-main-404__inner">
            {% if section.settings.show_code %}
                <h1 class="tiendu-main-404__code">{{ section.settings.code_text }}</h1>
            {% endif %}
            {% if section.settings.title != blank %}
                <p class="tiendu-main-404__title">{{ section.settings.title }}</p>
            {% endif %}
            {% if section.settings.message != blank %}
                <p class="tiendu-main-404__message">{{ section.settings.message }}</p>
            {% endif %}
            {% if section.settings.button_text != blank %}
                <a href="{{ section.settings.button_url }}" class="tiendu-main-404__button">
                    {{ section.settings.button_text }}
                </a>
            {% endif %}
        </div>
    {% endif %}
</section>

<style>
    .tiendu-main-404 {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        padding: 64px var(--container-horizontal-padding, 8px);
        text-align: center;
    }

    .tiendu-main-404__inner {
        max-width: 480px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
    }

    .tiendu-main-404__code {
        font-family: var(--font-heading-family);
        font-size: 6rem;
        font-weight: 700;
        line-height: 1;
        color: var(--color-primary);
        margin: 0;
    }

    .tiendu-main-404__title {
        font-family: var(--font-heading-family);
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--color-text);
        margin: 0;
    }

    .tiendu-main-404__message {
        font-size: 1rem;
        color: var(--color-text);
        opacity: 0.8;
        margin: 0;
    }

    .tiendu-main-404__button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-top: 8px;
        padding: 12px 24px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        color: #ffffff;
        background-color: var(--color-primary);
        border-radius: var(--button-input-border-radius, 0.375rem);
        transition: opacity 0.15s ease;
    }

    .tiendu-main-404__button:hover {
        opacity: 0.9;
    }

    @media (max-width: 48rem) {
        .tiendu-main-404 {
            padding: 40px var(--container-horizontal-padding, 8px);
        }

        .tiendu-main-404__code {
            font-size: 4rem;
        }

        .tiendu-main-404__title {
            font-size: 1.25rem;
        }
    }
</style>

{% schema %}
{
    "name": "Main 404",
    "enabled_on": {
        "templates": [
            "404"
        ]
    },
    "settings": [
        {
            "type": "checkbox",
            "id": "show_code",
            "label": "Mostrar código 404",
            "default": true
        },
        {
            "type": "text",
            "id": "code_text",
            "label": "Texto del código",
            "default": "404"
        },
        {
            "type": "text",
            "id": "title",
            "label": "Título",
            "default": "Página no encontrada"
        },
        {
            "type": "textarea",
            "id": "message",
            "label": "Mensaje",
            "default": "La página que buscás no existe o fue movida."
        },
        {
            "type": "text",
            "id": "button_text",
            "label": "Texto del botón",
            "default": "Volver al inicio"
        },
        {
            "type": "url",
            "id": "button_url",
            "label": "URL del botón",
            "default": "/"
        }
    ],
    "max_blocks": 1,
    "blocks": [
        {
            "type": "layout"
        },
        {
            "type": "text"
        },
        {
            "type": "button"
        },
        {
            "type": "image"
        },
        {
            "type": "link"
        }
    ],
    "presets": [
        {
            "name": "Main 404",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 64px var(--container-horizontal-padding, 8px); display: flex; justify-content: center; align-items: center; min-height: 60vh;",
                        "css_styles_tablet": "padding: 40px var(--container-horizontal-padding, 8px);",
                        "css_styles_mobile": "padding: 32px var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: 480px; display: flex; flex-direction: column; align-items: center; gap: 16px; text-align: center;"
                            },
                            "blocks": {
                                "code": {
                                    "type": "text",
                                    "settings": {
                                        "text": "404",
                                        "text_type": "page_title",
                                        "size_desktop": "6xl",
                                        "size_tablet": "5xl",
                                        "size_mobile": "4xl",
                                        "css_styles_desktop": "color: var(--color-primary); line-height: 1;"
                                    }
                                },
                                "title": {
                                    "type": "text",
                                    "settings": {
                                        "text": "Página no encontrada",
                                        "text_type": "section_title",
                                        "bold": true,
                                        "size_desktop": "2xl",
                                        "size_tablet": "xl",
                                        "size_mobile": "lg"
                                    }
                                },
                                "message": {
                                    "type": "text",
                                    "settings": {
                                        "text": "La página que buscás no existe o fue movida.",
                                        "text_type": "paragraph",
                                        "size_desktop": "base",
                                        "size_mobile": "sm"
                                    }
                                },
                                "button": {
                                    "type": "link",
                                    "preset": "primary",
                                    "settings": {
                                        "text": "Volver al inicio",
                                        "url": "/"
                                    }
                                }
                            },
                            "block_order": [
                                "code",
                                "title",
                                "message",
                                "button"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
