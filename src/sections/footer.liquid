<footer class="tiendu-footer">
    {% content_for "blocks" %}
</footer>

{% schema %}
{
    "name": "Footer",
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "@theme"
        }
    ],
    "presets": [
        {
            "name": "Minimal",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 0 var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: var(--container-max-width, 1024px);\nmargin: 0 auto;\ndisplay: flex;\nflex-direction: column;\ngap: 80px;\npadding: 64px 0 32px;",
                                "css_styles_tablet": "gap: 72px;\npadding: 48px 0 24px;",
                                "css_styles_mobile": "gap: 64px;\npadding: 40px 0 24px;"
                            },
                            "blocks": {
                                "layout_columns": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: grid;\ngrid-template-columns: repeat(3, minmax(0, 1fr));\ngap: 40px;",
                                        "css_styles_tablet": "gap: 24px;",
                                        "css_styles_mobile": "grid-template-columns: 1fr;\ngap: 32px;"
                                    },
                                    "blocks": {
                                        "layout_business": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex;\nflex-direction: column;\ngap: 12px;"
                                            },
                                            "blocks": {
                                                "store_name": {
                                                    "type": "store__name",
                                                    "blocks": {
                                                        "default-text": {
                                                            "type": "text",
                                                            "static": true,
                                                            "settings": {
                                                                "text_type": "subtitle",
                                                                "bold": true,
                                                                "size_desktop": "xl"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "default-text"
                                                    ]
                                                },
                                                "text_business_body": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Una selección cuidada de productos, promociones y novedades para que tu tienda se vea clara y actual.",
                                                        "text_type": "paragraph",
                                                        "size_desktop": "base",
                                                        "css_styles_desktop": "max-width: 32ch;\nopacity: 0.8;"
                                                    }
                                                },
                                                "layout_social": {
                                                    "type": "layout",
                                                    "settings": {
                                                        "css_styles_desktop": "display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-top: 4px;"
                                                    },
                                                    "blocks": {
                                                        "link_instagram": {
                                                            "type": "link",
                                                            "settings": {
                                                                "url": "",
                                                                "css_styles_desktop": "display: inline-flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border-radius: 9999px; background: rgba(0, 0, 0, 0.04);"
                                                            },
                                                            "blocks": {
                                                                "icon": {
                                                                    "type": "icon",
                                                                    "settings": {
                                                                        "icon": "instagram",
                                                                        "color": "custom",
                                                                        "custom_color": "#111827",
                                                                        "size": "sm"
                                                                    }
                                                                }
                                                            },
                                                            "block_order": [
                                                                "icon"
                                                            ]
                                                        },
                                                        "link_facebook": {
                                                            "type": "link",
                                                            "settings": {
                                                                "url": "",
                                                                "css_styles_desktop": "display: inline-flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border-radius: 9999px; background: rgba(0, 0, 0, 0.04);"
                                                            },
                                                            "blocks": {
                                                                "icon": {
                                                                    "type": "icon",
                                                                    "settings": {
                                                                        "icon": "facebook",
                                                                        "color": "custom",
                                                                        "custom_color": "#111827",
                                                                        "size": "sm"
                                                                    }
                                                                }
                                                            },
                                                            "block_order": [
                                                                "icon"
                                                            ]
                                                        },
                                                        "link_youtube": {
                                                            "type": "link",
                                                            "settings": {
                                                                "url": "",
                                                                "css_styles_desktop": "display: inline-flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border-radius: 9999px; background: rgba(0, 0, 0, 0.04);"
                                                            },
                                                            "blocks": {
                                                                "icon": {
                                                                    "type": "icon",
                                                                    "settings": {
                                                                        "icon": "youtube",
                                                                        "color": "custom",
                                                                        "custom_color": "#111827",
                                                                        "size": "sm"
                                                                    }
                                                                }
                                                            },
                                                            "block_order": [
                                                                "icon"
                                                            ]
                                                        },
                                                        "link_tiktok": {
                                                            "type": "link",
                                                            "settings": {
                                                                "url": "",
                                                                "css_styles_desktop": "display: inline-flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border-radius: 9999px; background: rgba(0, 0, 0, 0.04);"
                                                            },
                                                            "blocks": {
                                                                "icon": {
                                                                    "type": "icon",
                                                                    "settings": {
                                                                        "icon": "tiktok",
                                                                        "color": "custom",
                                                                        "custom_color": "#111827",
                                                                        "size": "sm"
                                                                    }
                                                                }
                                                            },
                                                            "block_order": [
                                                                "icon"
                                                            ]
                                                        }
                                                    },
                                                    "block_order": [
                                                        "link_instagram",
                                                        "link_facebook",
                                                        "link_youtube",
                                                        "link_tiktok"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "store_name",
                                                "text_business_body",
                                                "layout_social"
                                            ]
                                        },
                                        "layout_collections": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex;\nflex-direction: column;\ngap: 10px;"
                                            },
                                            "blocks": {
                                                "text_collections_title": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Colecciones",
                                                        "text_type": "subtitle",
                                                        "bold": true,
                                                        "size_desktop": "lg",
                                                        "css_styles_desktop": "margin-bottom: 6px;"
                                                    }
                                                },
                                                "link_collection_one": {
                                                    "type": "link",
                                                    "preset": "default",
                                                    "settings": {
                                                        "url": ""
                                                    },
                                                    "blocks": {
                                                        "text": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "Verano"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "text"
                                                    ]
                                                },
                                                "link_collection_two": {
                                                    "type": "link",
                                                    "preset": "default",
                                                    "settings": {
                                                        "url": ""
                                                    },
                                                    "blocks": {
                                                        "text": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "Nuevos ingresos"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "text"
                                                    ]
                                                },
                                                "link_collection_three": {
                                                    "type": "link",
                                                    "preset": "default",
                                                    "settings": {
                                                        "url": ""
                                                    },
                                                    "blocks": {
                                                        "text": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "Favoritos"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "text"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "text_collections_title",
                                                "link_collection_one",
                                                "link_collection_two",
                                                "link_collection_three"
                                            ]
                                        },
                                        "layout_info": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex;\nflex-direction: column;\ngap: 10px;"
                                            },
                                            "blocks": {
                                                "text_info_title": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "+ Información",
                                                        "text_type": "subtitle",
                                                        "bold": true,
                                                        "size_desktop": "lg",
                                                        "css_styles_desktop": "margin-bottom: 6px;"
                                                    }
                                                },
                                                "link_info_one": {
                                                    "type": "link",
                                                    "preset": "default",
                                                    "settings": {
                                                        "url": ""
                                                    },
                                                    "blocks": {
                                                        "text": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "Sobre nosotros"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "text"
                                                    ]
                                                },
                                                "link_info_two": {
                                                    "type": "link",
                                                    "preset": "default",
                                                    "settings": {
                                                        "url": ""
                                                    },
                                                    "blocks": {
                                                        "text": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "Envios y cambios"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "text"
                                                    ]
                                                },
                                                "link_info_three": {
                                                    "type": "link",
                                                    "preset": "default",
                                                    "settings": {
                                                        "url": ""
                                                    },
                                                    "blocks": {
                                                        "text": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "Contacto"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "text"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "text_info_title",
                                                "link_info_one",
                                                "link_info_two",
                                                "link_info_three"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "layout_business",
                                        "layout_collections",
                                        "layout_info"
                                    ]
                                },
                                "text_legal": {
                                    "type": "text",
                                    "settings": {
                                        "text": "® 2026 Todos los derechos registrados.",
                                        "text_type": "paragraph",
                                        "size_desktop": "sm",
                                        "css_styles_desktop": "opacity: 0.7;"
                                    }
                                }
                            },
                            "block_order": [
                                "layout_columns",
                                "text_legal"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
