<section class="t-related-products"{% if settings.animations %} data-fly-in-intro{% endif %}>
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Add blocks to build the related products.</div>
    {% endif %}
</section>

{% schema %}
{
    "name": "Related products",
    "enabled_on": {
        "templates": [
            "product"
        ]
    },
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Related products",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 64px var(--container-horizontal-padding, 8px);",
                        "css_styles_tablet": "padding: 40px var(--container-horizontal-padding, 8px);",
                        "css_styles_mobile": "padding: 32px var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: var(--container-max-width, 1024px); margin: 0 auto; display: flex; flex-direction: column; gap: 24px;"
                            },
                            "blocks": {
                                "title": {
                                    "type": "text",
                                    "settings": {
                                        "text": "Productos relacionados",
                                        "text_type": "section_title",
                                        "size_desktop": "2xl",
                                        "size_tablet": "xl",
                                        "size_mobile": "lg"
                                    }
                                },
                                "layout_grid": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 24px;",
                                        "css_styles_tablet": "grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;",
                                        "css_styles_mobile": "grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px;"
                                    },
                                    "blocks": {
                                        "products": {
                                            "type": "product-related-products",
                                            "settings": {
                                                "limit": 4
                                            },
                                            "blocks": {
                                                "product_card": {
                                                    "type": "product",
                                                    "preset": "default",
                                                    "static": true
                                                }
                                            },
                                            "block_order": [
                                                "product_card"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "products"
                                    ]
                                }
                            },
                            "block_order": [
                                "title",
                                "layout_grid"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
