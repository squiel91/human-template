<section class="t-breadcrumbs-section" style="padding: 16px 0;"{% assign show_animation = settings.animations %}{% if section.settings.enter_animation == "yes" %}{% assign show_animation = true %}{% elsif section.settings.enter_animation == "no" %}{% assign show_animation = false %}{% endif %}{% if show_animation %} data-fly-in-intro{% endif %}>
    {% content_for 'blocks' %}
</section>

{% schema %}
{
    "name": "Breadcrumbs",
    "max_blocks": 1,
    "settings": [
        {
            "type": "select",
            "id": "enter_animation",
            "label": "Enter animation",
            "default": "theme_default",
            "options": [
                {
                    "value": "theme_default",
                    "label": "Theme default"
                },
                {
                    "value": "no",
                    "label": "No enter animation"
                },
                {
                    "value": "yes",
                    "label": "Enter animation"
                }
            ]
        }
    ],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "default",
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 0 var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: var(--container-max-width, 1024px); margin: 0 auto;"
                            },
                            "blocks": {
                                "breadcrumbs": {
                                    "type": "breadcrumb-trail",
                                    "settings": {
                                        "home_label": "Inicio",
                                        "separator_icon": "chevron-right",
                                        "show_current": true
                                    }
                                }
                            },
                            "block_order": [
                                "breadcrumbs"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
