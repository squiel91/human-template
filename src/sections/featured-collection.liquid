<section class="t-featured-collection"{% assign show_animation = settings.animations %}{% if section.settings.enter_animation == "yes" %}{% assign show_animation = true %}{% elsif section.settings.enter_animation == "no" %}{% assign show_animation = false %}{% endif %}{% if show_animation %} data-fly-in-intro{% endif %}>
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Add blocks to build the featured collection.</div>
    {% endif %}
</section>

{% schema %}
{
    "name": "Featured collection",
    "max_blocks": 1,
    "settings": [
        {
            "type": "collection",
            "id": "collection",
            "label": "Collection"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "label": "Products to show",
            "min": 2,
            "max": 12,
            "step": 1,
            "default": 4
        },
        {
            "type": "select",
            "id": "enter_animation",
            "label": "Enter animation",
            "default": "theme_default",
            "options": [
                {
                    "value": "theme_default",
                    "label": "Theme default"
                },
                {
                    "value": "no",
                    "label": "No enter animation"
                },
                {
                    "value": "yes",
                    "label": "Enter animation"
                }
            ]
        }
    ],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Featured collection",
            "settings": {
                "products_to_show": 4
            },
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "padding: 64px var(--container-horizontal-padding, 8px);",
                        "css_styles_tablet": "padding: 40px var(--container-horizontal-padding, 8px);",
                        "css_styles_mobile": "padding: 32px var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "max-width: var(--container-max-width, 1024px); margin: 0 auto; display: flex; flex-direction: column; gap: 32px;",
                                "css_styles_tablet": "gap: 24px;",
                                "css_styles_mobile": "gap: 20px;"
                            },
                            "blocks": {
                                "layout_header": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; row-gap: 8px; column-gap: 16px;"
                                    },
                                    "blocks": {
                                        "title": {
                                            "type": "_text-for-featured-collection",
                                            "blocks": {
                                                "default-text": {
                                                    "type": "text",
                                                    "static": true,
                                                    "settings": {
                                                        "text_type": "section_title",
                                                        "size_desktop": "4xl",
                                                        "size_tablet": "3xl",
                                                        "size_mobile": "2xl"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "default-text"
                                            ]
                                        },
                                        "cta": {
                                            "type": "link",
                                            "preset": "secondary",
                                            "settings": {
                                                "url": "/categorias"
                                            },
                                            "blocks": {
                                                "text": {
                                                    "type": "text",
                                                    "settings": {
                                                        "text": "Ver más"
                                                    }
                                                },
                                                "icon": {
                                                    "type": "icon",
                                                    "settings": {
                                                        "icon": "chevron-right",
                                                        "size": "sm",
                                                        "stroke_width": "2.5"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "text",
                                                "icon"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "title",
                                        "cta"
                                    ]
                                },
                                "layout_grid": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 24px;",
                                        "css_styles_tablet": "grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;",
                                        "css_styles_mobile": "grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px;"
                                    },
                                    "blocks": {
                                        "products": {
                                            "type": "collection-products",
                                            "blocks": {
                                                "product_card": {
                                                    "type": "product",
                                                    "preset": "default",
                                                    "static": true
                                                }
                                            },
                                            "block_order": [
                                                "product_card"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "products"
                                    ]
                                }
                            },
                            "block_order": [
                                "layout_header",
                                "layout_grid"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
