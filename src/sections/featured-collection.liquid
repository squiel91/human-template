<section class="tiendu-featured-collection" style="padding: 32px 0;">
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Agrega bloques para construir la colección destacada.</div>
    {% endif %}
</section>

{% schema %}
{
    "name": "Colección destacada",
    "max_blocks": 1,
    "settings": [
        {
            "type": "collection",
            "id": "collection",
            "label": "Colección"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "label": "Productos a mostrar",
            "min": 2,
            "max": 12,
            "step": 1,
            "default": 4
        }
    ],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Colección destacada",
            "settings": {
                "products_to_show": 4
            },
            "blocks": {
                "layout_outer": {
                    "type": "layout",
                    "settings": {
                        "image_desktop": "",
                        "background_color_desktop": "",
                        "css_styles_desktop": "padding: 0 8px;",
                        "image_tablet": "",
                        "background_color_tablet": "",
                        "css_styles_tablet": "",
                        "image_mobile": "",
                        "background_color_mobile": "",
                        "css_styles_mobile": ""
                    },
                    "blocks": {
                        "layout_inner": {
                            "type": "layout",
                            "settings": {
                                "image_desktop": "",
                                "background_color_desktop": "",
                                "css_styles_desktop": "max-width: 1024px; margin: 0 auto; display: flex; flex-direction: column; gap: 32px;",
                                "image_tablet": "",
                                "background_color_tablet": "",
                                "css_styles_tablet": "gap: 24px;",
                                "image_mobile": "",
                                "background_color_mobile": "",
                                "css_styles_mobile": "gap: 20px;"
                            },
                            "blocks": {
                                "layout_header": {
                                    "type": "layout",
                                    "settings": {
                                        "image_desktop": "",
                                        "background_color_desktop": "",
                                        "css_styles_desktop": "display: flex; align-items: center; justify-content: space-between; gap: 16px;",
                                        "image_tablet": "",
                                        "background_color_tablet": "",
                                        "css_styles_tablet": "",
                                        "image_mobile": "",
                                        "background_color_mobile": "",
                                        "css_styles_mobile": "flex-direction: column; align-items: flex-start;"
                                    },
                                    "blocks": {
                                        "title": {
                                            "type": "_text-for-featured-collection",
                                            "settings": {},
                                            "blocks": {
                                                "default-text": {
                                                    "type": "text",
                                                    "static": true,
                                                    "settings": {
                                                        "text": "",
                                                        "text_type": "section_title",
                                                        "color": "custom",
                                                        "custom_color": "#000000",
                                                        "bold": true,
                                                        "italic": false,
                                                        "underline": false,
                                                        "line_through": false,
                                                        "size_desktop": "2xl",
                                                        "size_tablet": "",
                                                        "size_mobile": "",
                                                        "css_styles_desktop": "",
                                                        "css_styles_tablet": "",
                                                        "css_styles_mobile": ""
                                                    },
                                                    "blocks": {}
                                                }
                                            },
                                            "block_order": [
                                                "default-text"
                                            ]
                                        },
                                        "cta": {
                                            "type": "_button-for-featured-collection",
                                            "settings": {},
                                            "blocks": {
                                                "default-button": {
                                                    "type": "button",
                                                    "static": true,
                                                    "settings": {
                                                        "text": "Ver más",
                                                        "link": "",
                                                        "icon_position": "after",
                                                        "color": "primary",
                                                        "size": "md",
                                                        "variant": "secondary",
                                                        "rounding": "none",
                                                        "css_styles_desktop": "",
                                                        "css_styles_tablet": "",
                                                        "css_styles_mobile": ""
                                                    },
                                                    "blocks": {}
                                                }
                                            },
                                            "block_order": [
                                                "default-button"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "title",
                                        "cta"
                                    ]
                                },
                                "layout_grid": {
                                    "type": "layout",
                                    "settings": {
                                        "image_desktop": "",
                                        "background_color_desktop": "",
                                        "css_styles_desktop": "display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 24px;",
                                        "image_tablet": "",
                                        "background_color_tablet": "",
                                        "css_styles_tablet": "grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px;",
                                        "image_mobile": "",
                                        "background_color_mobile": "",
                                        "css_styles_mobile": "grid-template-columns: 1fr; gap: 16px;"
                                    },
                                    "blocks": {
                                        "products": {
                                            "type": "collection-products",
                                            "settings": {},
                                            "blocks": {
                                                "product_card": {
                                                    "type": "product",
                                                    "static": true,
                                                    "settings": {
                                                        "rounding": "none",
                                                        "css_styles_desktop": "",
                                                        "css_styles_tablet": "",
                                                        "css_styles_mobile": ""
                                                    },
                                                    "blocks": {
                                                        "card_wrap": {
                                                            "type": "layout",
                                                            "settings": {
                                                                "css_styles_desktop": "display: flex; flex-direction: column; gap: 8px;",
                                                                "css_styles_tablet": "",
                                                                "css_styles_mobile": ""
                                                            },
                                                            "blocks": {
                                                                "card_image": {
                                                                    "type": "product__image",
                                                                    "settings": {
                                                                        "image_ratio": "square",
                                                                        "rounding": "none",
                                                                        "transition_to_second_image": false,
                                                                        "css_styles_desktop": "",
                                                                        "css_styles_tablet": "",
                                                                        "css_styles_mobile": ""
                                                                    },
                                                                    "blocks": {}
                                                                },
                                                                "card_title": {
                                                                    "type": "product__title",
                                                                    "settings": {},
                                                                    "blocks": {
                                                                        "default-text": {
                                                                            "type": "text",
                                                                            "static": true,
                                                                            "settings": {
                                                                                "custom_color": "#000000"
                                                                            },
                                                                            "blocks": {}
                                                                        }
                                                                    },
                                                                    "block_order": ["default-text"]
                                                                },
                                                                "card_price": {
                                                                    "type": "product__price",
                                                                    "settings": {},
                                                                    "blocks": {
                                                                        "default-text": {
                                                                            "type": "text",
                                                                            "static": true,
                                                                            "settings": {
                                                                                "custom_color": "#000000",
                                                                                "bold": true
                                                                            },
                                                                            "blocks": {}
                                                                        }
                                                                    },
                                                                    "block_order": ["default-text"]
                                                                }
                                                            },
                                                            "block_order": ["card_image", "card_title", "card_price"]
                                                        }
                                                    },
                                                    "block_order": ["card_wrap"]
                                                }
                                            },
                                            "block_order": [
                                                "product_card"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "products"
                                    ]
                                }
                            },
                            "block_order": [
                                "layout_header",
                                "layout_grid"
                            ]
                        }
                    },
                    "block_order": [
                        "layout_inner"
                    ]
                }
            },
            "block_order": [
                "layout_outer"
            ]
        }
    ]
}
{% endschema %}
