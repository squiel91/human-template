{% assign contact_button_id = 'tiendu__contact-button-' | append: section.id %}

<style>
    #{{ contact_button_id }} {
        position: fixed;
        right: 24px;
        bottom: 24px;
        z-index: var(--z-contact-button, 40);
        display: flex;
        pointer-events: none;
    }

    #{{ contact_button_id }} > * {
        pointer-events: auto;
    }

    @media (width <= 48rem) {
        #{{ contact_button_id }} {
            right: 16px;
            bottom: 16px;
        }
    }
</style>

<section id="{{ contact_button_id }}" class="tiendu-contact-button">
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Add a contact button.</div>
    {% endif %}
</section>

{% schema %}
{
    "name": "Contact button",
    "enabled_on": {
        "groups": [
            "footer"
        ]
    },
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "link"
        }
    ],
    "presets": [
        {
            "name": "Contact button",
            "blocks": {
                "button": {
                    "type": "link",
                    "preset": "primary",
                    "settings": {
                        "url": "https://wa.me/59899424414?text=Hola! Tengo una consulta de algo que vi en su tienda web.",
                        "open_in_new_tab": true,
                        "css_styles_desktop": "height: 64px;\nwidth: 64px;\ndisplay: flex;\njustify-content: center;\nalign-items: center;\nbox-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);\nbackground-color: var(--primary-color);\nborder-radius: 100%;\ncolor: white;\npadding: 0;",
                        "css_styles_mobile": "height: 64px;\nwidth: 64px;\ndisplay: flex;\njustify-content: center;\nalign-items: center;\nbox-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);\nbackground-color: var(--primary-color);\nborder-radius: 100%;\ncolor: white;\npadding: 0;"
                    },
                    "blocks": {
                        "icon": {
                            "type": "icon",
                            "settings": {
                                "icon": "messages-square",
                                "color": "custom",
                                "size": "lg",
                                "stroke_width": "1.5"
                            }
                        }
                    },
                    "block_order": [
                        "icon"
                    ]
                }
            },
            "block_order": [
                "button"
            ]
        }
    ]
}
{% endschema %}
