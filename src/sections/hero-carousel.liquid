<section class="tiendu-hero-carousel">
    {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div style="padding: 4rem 1rem; text-align: center;">Add a carousel to this section.</div>
    {% endif %}
</section>

{% schema %}
{
    "name": "Hero carousel",
    "disabled_on": {
        "groups": [
            "header",
            "footer"
        ]
    },
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "carousel"
        }
    ],
    "presets": [
        {
            "name": "Hero carousel",
            "blocks": {
                "carousel": {
                    "type": "carousel",
                    "settings": {
                        "height_desktop": "28rem",
                        "height_tablet": "",
                        "height_mobile": "",
                        "show_arrows": true,
                        "show_dots": true,
                        "autoplay": true,
                        "autoplay_seconds": 5
                    },
                    "blocks": {
                        "slide_1": {
                            "type": "slide"
                        },
                        "slide_2": {
                            "type": "slide"
                        }
                    },
                    "block_order": [
                        "slide_1",
                        "slide_2"
                    ]
                }
            },
            "block_order": [
                "carousel"
            ]
        }
    ]
}
{% endschema %}
