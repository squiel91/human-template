{% layout 'empty' %}
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Calculadora de Repuestos – TecnoJcUy</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#f5f2eb;--bg2:#ece8df;--surface:#fff;--surface2:#f0ece3;
  --border:#d8d2c5;--border2:#c8c0b0;--ink:#1a1a14;--ink2:#4a4a3a;--muted:#8a8470;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--ink);font-family:'Space Grotesk',sans-serif;min-height:100vh;}
.wrap{max-width:900px;margin:0 auto;padding:28px 16px 80px;}

/* HEADER */
header{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;
  margin-bottom:24px;padding-bottom:18px;border-bottom:2px solid var(--ink);flex-wrap:wrap;}
header h1{font-size:22px;font-weight:700;letter-spacing:-.03em;}
header h1 span{background:var(--ink);color:var(--bg);padding:0 7px;border-radius:4px;margin-right:5px;}
.sub{margin-top:5px;font-size:10px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;font-family:'Courier Prime',monospace;}
.hdr-r{display:flex;flex-direction:column;align-items:flex-end;gap:5px;}
.hdr-lbl{font-size:9px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);font-family:'Courier Prime',monospace;}
.cur-tgl{display:flex;gap:4px;}
.cur-btn{padding:4px 10px;border:1.5px solid var(--border2);background:transparent;border-radius:4px;
  font-family:'Courier Prime',monospace;font-size:11px;color:var(--ink2);cursor:pointer;transition:all .12s;}
.cur-btn.active{background:var(--ink);color:var(--bg);border-color:var(--ink);}

/* STATS */
.stats{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;}
.stat{background:var(--surface);border:1px solid var(--border);border-radius:6px;
  padding:6px 11px;font-size:10px;color:var(--muted);font-family:'Courier Prime',monospace;}
.stat strong{color:var(--ink);font-size:12px;display:block;}

/* STEP */
.step{display:flex;align-items:center;gap:9px;margin-bottom:11px;}
.step-n{width:22px;height:22px;background:var(--ink);color:var(--bg);border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-family:'Courier Prime',monospace;font-size:10px;font-weight:700;flex-shrink:0;}
.step-t{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}

/* SEARCH */
.search-wrap{position:relative;margin-bottom:5px;}
.search-input{width:100%;padding:12px 15px 12px 42px;border:2px solid var(--border2);border-radius:10px;
  background:var(--surface);color:var(--ink);font-family:'Space Grotesk',sans-serif;font-size:14px;
  outline:none;transition:border .15s;}
.search-input:focus{border-color:var(--ink);}
.search-input::placeholder{color:var(--muted);}
.search-icon{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:16px;pointer-events:none;}
.search-clear{position:absolute;right:11px;top:50%;transform:translateY(-50%);
  background:none;border:none;cursor:pointer;color:var(--muted);font-size:19px;display:none;line-height:1;}
.search-clear.show{display:block;}

/* DROPDOWN */
.drop{position:absolute;top:calc(100%+4px);left:0;right:0;background:var(--surface);
  border:1.5px solid var(--border2);border-radius:10px;
  box-shadow:0 8px 24px rgba(0,0,0,.10);z-index:200;max-height:300px;overflow-y:auto;display:none;}
.drop.open{display:block;}
.di{display:flex;align-items:center;justify-content:space-between;padding:9px 13px;
  cursor:pointer;transition:background .1s;border-bottom:1px solid var(--border);gap:10px;}
.di:last-child{border-bottom:none;}
.di:hover{background:var(--bg2);}
.di-name{font-size:12px;font-weight:600;color:var(--ink);}
.di-sub{font-size:10px;color:var(--muted);font-family:'Courier Prime',monospace;margin-top:1px;}
.di-r{display:flex;align-items:center;gap:7px;flex-shrink:0;}
.di-marca{font-size:9px;padding:2px 6px;border-radius:3px;font-weight:600;
  background:var(--bg2);color:var(--ink2);}
.di-tipo{font-size:9px;padding:2px 6px;border-radius:3px;font-weight:600;}
.di-precio{font-family:'Courier Prime',monospace;font-size:12px;font-weight:700;color:var(--ink);}
.no-res{padding:18px;text-align:center;color:var(--muted);font-family:'Courier Prime',monospace;font-size:12px;}

/* TIPO PILLS */
.tipo-pills{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px;}
.tipo-pill{padding:5px 12px;border:1.5px solid var(--border2);background:transparent;border-radius:20px;
  font-family:'Space Grotesk',sans-serif;font-size:11px;font-weight:600;cursor:pointer;
  transition:all .12s;color:var(--ink2);}
.tipo-pill:hover{border-color:var(--ink);}
.tipo-pill.active{background:var(--ink);color:var(--bg);border-color:var(--ink);}

/* CHIP SELECCIONADO */
.sel-chip{display:none;padding:10px 14px;background:var(--ink);color:var(--bg);
  border-radius:8px;margin-bottom:14px;gap:10px;}
.sel-chip.show{display:flex;align-items:flex-start;justify-content:space-between;}
.sc-main{font-weight:600;font-size:13px;line-height:1.3;}
.sc-sub{font-size:10px;opacity:.6;font-family:'Courier Prime',monospace;margin-top:2px;}
.sc-x{background:none;border:none;color:var(--bg);cursor:pointer;font-size:19px;opacity:.6;flex-shrink:0;line-height:1;}
.sc-x:hover{opacity:1;}

/* MO SECTION */
.mo-section{background:var(--surface);border:1.5px solid var(--border);border-radius:12px;
  padding:18px;margin-bottom:14px;display:none;}
.mo-section.show{display:block;}
.sec-t{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);
  font-family:'Courier Prime',monospace;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.sec-t::after{content:'';flex:1;height:1px;background:var(--border);}
.mo-pills{display:flex;gap:8px;flex-wrap:wrap;}
.mo-pill{padding:8px 14px;border:1.5px solid var(--border);border-radius:8px;background:var(--surface2);
  cursor:pointer;transition:all .12s;text-align:left;}
.mo-pill:hover{border-color:var(--ink2);}
.mo-pill.active{border-color:var(--ink);background:var(--bg2);}
.mo-label{font-size:10px;color:var(--muted);font-family:'Courier Prime',monospace;margin-bottom:3px;}
.mo-val{font-size:16px;font-weight:700;letter-spacing:-.02em;}
.mo-desc{font-size:9px;color:var(--muted);margin-top:2px;}

/* RESULTADO FINAL */
.result-box{background:var(--ink);border-radius:12px;padding:22px;display:none;color:var(--bg);}
.result-box.show{display:block;}
.rb-title{font-size:10px;letter-spacing:.12em;text-transform:uppercase;
  color:rgba(245,242,235,.5);font-family:'Courier Prime',monospace;margin-bottom:16px;
  display:flex;align-items:center;gap:8px;}
.rb-title::after{content:'';flex:1;height:1px;background:rgba(255,255,255,.12);}
.rb-rows{display:flex;flex-direction:column;gap:7px;margin-bottom:14px;}
.rb-row{display:flex;justify-content:space-between;align-items:center;font-size:12px;}
.rb-row .rl{color:rgba(245,242,235,.55);}
.rb-row .rv{font-family:'Courier Prime',monospace;font-weight:700;}
.rb-row.hl .rl{color:rgba(245,242,235,.8);}
.rb-row.hl .rv{color:#7effd4;}
.rb-div{height:1px;background:rgba(255,255,255,.1);margin:12px 0;}
.rb-totals{display:flex;flex-direction:column;gap:6px;margin-bottom:12px;}
.rb-tot{display:flex;justify-content:space-between;align-items:center;
  padding:10px 13px;background:rgba(255,255,255,.07);border-radius:8px;border:1.5px solid rgba(255,255,255,.1);}
.rb-tot.main{background:rgba(255,255,255,.12);border-color:rgba(126,255,212,.3);}
.rt-lbl{font-size:10px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:rgba(245,242,235,.6);}
.rb-tot.main .rt-lbl{color:rgba(245,242,235,.85);}
.rt-val{font-size:20px;font-weight:700;letter-spacing:-.03em;color:rgba(245,242,235,.6);}
.rb-tot.main .rt-val{font-size:26px;color:#7effd4;}
.rb-nota{font-size:10px;color:rgba(245,242,235,.3);font-family:'Courier Prime',monospace;line-height:1.6;}
.rb-actions{display:flex;gap:7px;margin-top:14px;flex-wrap:wrap;}
.btn{padding:8px 15px;border-radius:6px;font-family:'Space Grotesk',sans-serif;font-size:11px;
  font-weight:600;cursor:pointer;border:1.5px solid transparent;transition:all .12s;}
.btn-p{background:rgba(255,255,255,.15);color:var(--bg);border-color:rgba(255,255,255,.2);}
.btn-p:hover{background:rgba(255,255,255,.25);}
.btn-o{background:transparent;color:rgba(245,242,235,.6);border-color:rgba(255,255,255,.15);}
.btn-o:hover{color:var(--bg);border-color:rgba(255,255,255,.4);}

/* TIPO COLORES */
.t-pantalla{background:#dbeafe;color:#1e40af;}
.t-bateria{background:#dcfce7;color:#166534;}
.t-flex_carga{background:#fef3c7;color:#92400e;}
.t-tapa_trasera{background:#f3e8ff;color:#6b21a8;}
.t-lens{background:#fce7f3;color:#9d174d;}
.t-tactil{background:#f0fdf4;color:#14532d;}

.footer{margin-top:32px;padding-top:16px;border-top:1.5px solid var(--border);
  font-size:10px;color:var(--muted);text-align:center;font-family:'Courier Prime',monospace;line-height:1.8;}

@media(max-width:480px){header{flex-direction:column;}.hdr-r{align-items:flex-start;}}
</style>
</head>
<body>
<div class="wrap">

<header>
  <div>
    <h1><span>TJ</span> Calculadora de Repuestos</h1>
    <p class="sub">TecnoJcUy · Galería Lapido N11 · 093 775 622 · Montevideo</p>
  </div>
  <div class="hdr-r">
    <span class="hdr-lbl">Moneda</span>
    <div class="cur-tgl">
      <button class="cur-btn active" onclick="setCurrency('UYU',this)">$ UYU</button>
      <button class="cur-btn" onclick="setCurrency('USD',this)">USD</button>
    </div>
  </div>
</header>

<div class="stats" id="statsBar"></div>

<!-- PASO 1: BUSCAR REPUESTO -->
<div class="step"><div class="step-n">1</div><div class="step-t">Buscá el repuesto por modelo</div></div>

<!-- Filtro por tipo -->
<div class="tipo-pills" id="tipoPills"></div>

<div style="position:relative;margin-bottom:14px;">
  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input class="search-input" id="searchInput" type="text"
      placeholder="Ej: Samsung A54, Redmi Note 12, iPhone 11, Moto G84…"
      autocomplete="off" oninput="onSearch(this.value)">
    <button class="search-clear" id="clearBtn" onclick="clearSearch()">×</button>
  </div>
  <div class="drop" id="drop"></div>
</div>

<!-- Chip del repuesto seleccionado -->
<div class="sel-chip" id="selChip">
  <div>
    <div class="sc-main" id="chipMain">—</div>
    <div class="sc-sub" id="chipSub">—</div>
  </div>
  <button class="sc-x" onclick="clearRepuesto()">×</button>
</div>

<!-- PASO 2: ELEGIR MO -->
<div class="mo-section" id="moSection">
  <div class="sec-t">2 · Elegí el precio de mano de obra</div>
  <div class="mo-pills" id="moPills"></div>
</div>

<!-- RESULTADO -->
<div class="result-box" id="resultBox">
  <div class="rb-title">💰 Precio total al cliente</div>
  <div class="rb-rows" id="rbRows"></div>
  <div class="rb-div"></div>
  <div class="rb-totals" id="rbTotals"></div>
  <div class="rb-nota" id="rbNota"></div>
  <div class="rb-actions">
    <button class="btn btn-p" onclick="window.print()">🖨 Imprimir</button>
    <button class="btn btn-o" onclick="doCopy()">📋 Copiar</button>
    <button class="btn btn-o" onclick="resetAll()">↺ Limpiar</button>
  </div>
</div>

<div class="footer">
  Precios de repuesto del proveedor · MO según tarifario TecnoJcUy · Comisión 15% sobre total<br>
  Actualizar planilla cada vez que cambien precios del proveedor<br>
  TecnoJcUy · 093 775 622 · Galería Lapido N11 · Av. 18 de Julio 948
</div>
</div>

