<script>
const USD_RATE = 40;
let currency = 'UYU';
let selRep = null;   // repuesto seleccionado
let selMO  = null;   // mano de obra seleccionada
let tipoFiltro = null;

function fmt(v){
  return currency==='UYU'
    ? '$ '+Math.round(v).toLocaleString('es-UY')
    : 'U$S '+Math.round(v/USD_RATE);
}
function setCurrency(c,btn){
  currency=c;
  document.querySelectorAll('.cur-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  if(selRep&&selMO) renderResult();
  if(selRep) renderMO();
}

// ── TARIFARIO MO (basado en tus precios reales) ──
// Detecta el tipo de equipo desde el nombre del repuesto y asigna MO
function getMOopciones(rep){
  const nombre = rep.n.toLowerCase();
  const marca  = rep.b;
  const tipo   = rep.t;

  // BASE SEGÚN TIPO DE REPARACIÓN
  let base_min, base_sug, base_prem;

  // Pantalla = más complejo
  if(tipo === 'pantalla'){
    // Detectar gama por marca/modelo
    if(nombre.includes('s24 ultra') || nombre.includes('s25 ultra') || nombre.includes('s23 ultra') || nombre.includes('s22 ultra')){
      base_min=2800; base_sug=3500; base_prem=4200;
    } else if(nombre.includes('s24+') || nombre.includes('s24 plus')){
      base_min=2500; base_sug=3000; base_prem=3600;
    } else if(nombre.includes('s24') || nombre.includes('s23') || nombre.includes('s22') || nombre.includes('s21 ultra')){
      base_min=2000; base_sug=2500; base_prem=3000;
    } else if(nombre.includes('s21') || nombre.includes('s20')){
      base_min=1700; base_sug=2000; base_prem=2500;
    } else if(nombre.includes('fold') || nombre.includes('flip') || nombre.includes('razr') || nombre.includes('magic v')){
      base_min=3500; base_sug=5000; base_prem=6500;
    } else if(nombre.includes('iphone 16 pro') || nombre.includes('iphone 15 pro') || nombre.includes('iphone 14 pro')){
      base_min=3000; base_sug=4000; base_prem=5000;
    } else if(nombre.includes('iphone 15') || nombre.includes('iphone 14') || nombre.includes('iphone 13 pro') || nombre.includes('iphone 12 pro')){
      base_min=2200; base_sug=2800; base_prem=3500;
    } else if(nombre.includes('iphone 13') || nombre.includes('iphone 12') || nombre.includes('iphone 11 pro')){
      base_min=1800; base_sug=2200; base_prem=2800;
    } else if(nombre.includes('iphone 11') || nombre.includes('iphone xr') || nombre.includes('iphone xs') || nombre.includes('iphone x ')){
      base_min=1500; base_sug=1800; base_prem=2200;
    } else if(nombre.includes('edge 40') || nombre.includes('edge 50') || nombre.includes('xiaomi 14') || nombre.includes('xiaomi 13') || nombre.includes('magic6') || nombre.includes('magic 6') || nombre.includes('magic5') || nombre.includes('magic 5')){
      base_min=1700; base_sug=2000; base_prem=2500;
    } else {
      // Gama baja/media — tu tarifa estándar
      base_min=1500; base_sug=1700; base_prem=2000;
    }
  } else if(tipo === 'bateria'){
    base_min=800; base_sug=900; base_prem=1100;
  } else if(tipo === 'flex_carga'){
    base_min=900; base_sug=1100; base_prem=1400;
  } else if(tipo === 'tapa_trasera'){
    base_min=900; base_sug=1100; base_prem=1500;
  } else if(tipo === 'lens'){
    base_min=700; base_sug=900; base_prem=1100;
  } else if(tipo === 'tactil'){
    base_min=1000; base_sug=1200; base_prem=1600;
  } else {
    base_min=800; base_sug=1000; base_prem=1300;
  }

  return [
    {label:'Mínima', val:base_min, desc:'Mercado bajo / urgente'},
    {label:'★ Sugerida', val:base_sug, desc:'Tu precio objetivo', main:true},
    {label:'Premium', val:base_prem, desc:'Garantía / dificultad'},
  ];
}

// ── TIPOS ──
const TIPOS = [
  {id:'pantalla',    label:'Pantalla',    emoji:'📱'},
  {id:'bateria',     label:'Batería',     emoji:'🔋'},
  {id:'flex_carga',  label:'Flex carga',  emoji:'⚡'},
  {id:'tapa_trasera',label:'Tapa trasera',emoji:'🔲'},
  {id:'lens',        label:'Lens cámara', emoji:'🔍'},
  {id:'tactil',      label:'Táctil',      emoji:'👆'},
];

const TIPO_LABELS = {
  pantalla:'Pantalla', bateria:'Batería', flex_carga:'Flex carga',
  tapa_trasera:'Tapa trasera', lens:'Lens cámara', tactil:'Táctil'
};

// ── RENDER TIPO PILLS ──
function renderTipoPills(){
  const div = document.getElementById('tipoPills');
  div.innerHTML = '<button class="tipo-pill'+(tipoFiltro===null?' active':'')+'" onclick="setTipo(null)">Todos</button>';
  TIPOS.forEach(t=>{
    div.innerHTML += `<button class="tipo-pill${tipoFiltro===t.id?' active':''}" onclick="setTipo('${t.id}')">${t.emoji} ${t.label}</button>`;
  });
}

function setTipo(t){
  tipoFiltro = t;
  renderTipoPills();
  const val = document.getElementById('searchInput').value;
  if(val.length>=2) onSearch(val);
}

// ── BÚSQUEDA ──
function onSearch(q){
  const drop = document.getElementById('drop');
  const cb   = document.getElementById('clearBtn');
  q = q.trim();
  cb.classList.toggle('show', q.length>0);
  if(q.length<2){drop.classList.remove('open');return;}

  const ql = q.toLowerCase();
  const terms = ql.split(' ').filter(w=>w.length>1);

  let matches = REPUESTOS.filter(r=>{
    if(tipoFiltro && r.t !== tipoFiltro) return false;
    const hay = (r.n+' '+r.b+' '+r.c).toLowerCase();
    return terms.every(w=>hay.includes(w));
  });

  // Ordenar: tipo pantalla primero, luego por precio asc
  matches.sort((a,b)=>{
    const order = ['pantalla','bateria','flex_carga','tapa_trasera','lens','tactil'];
    const oa = order.indexOf(a.t); const ob = order.indexOf(b.t);
    if(oa!==ob) return oa-ob;
    return a.p - b.p;
  });

  matches = matches.slice(0,20);

  if(matches.length===0){
    drop.innerHTML='<div class="no-res">Sin resultados — probá con otro término o cambiá el filtro</div>';
    drop.classList.add('open'); return;
  }

  drop.innerHTML = matches.map((r,i)=>{
    const tClass = 't-'+r.t;
    return `<div class="di" onclick="selectRep(${REPUESTOS.indexOf(r)})">
      <div>
        <div class="di-name">${r.n}</div>
        <div class="di-sub">${r.b} · ${r.c}</div>
      </div>
      <div class="di-r">
        <span class="di-tipo ${tClass}">${TIPO_LABELS[r.t]||r.t}</span>
        <span class="di-precio">${fmt(r.p)}</span>
      </div>
    </div>`;
  }).join('');
  drop.classList.add('open');
}

// ── SELECCIONAR REPUESTO ──
function selectRep(idx){
  selRep = REPUESTOS[idx];
  selMO  = null;
  document.getElementById('searchInput').value = selRep.n;
  document.getElementById('drop').classList.remove('open');
  document.getElementById('clearBtn').classList.add('show');

  // Chip
  const chip = document.getElementById('selChip');
  chip.classList.add('show');
  document.getElementById('chipMain').textContent = selRep.n;
  document.getElementById('chipSub').textContent =
    `${selRep.b} · ${selRep.c} · Precio proveedor: ${fmt(selRep.p)}`;

  // Mostrar MO
  renderMO();
  document.getElementById('resultBox').classList.remove('show');
}

// ── RENDER MO ──
function renderMO(){
  if(!selRep) return;
  const moSec = document.getElementById('moSection');
  moSec.classList.add('show');
  const pills = document.getElementById('moPills');
  const opciones = getMOopciones(selRep);
  pills.innerHTML = opciones.map((op,i)=>`
    <div class="mo-pill${selMO&&selMO.val===op.val?' active':''}" onclick="selectMO(${i})">
      <div class="mo-label">${op.label}</div>
      <div class="mo-val">${fmt(op.val)}</div>
      <div class="mo-desc">${op.desc}</div>
    </div>`).join('');
  // Autoselect sugerida
  if(!selMO){
    const sug = opciones.find(o=>o.main);
    if(sug){ selMO=sug; renderMO(); renderResult(); }
  }
}

function selectMO(i){
  const opciones = getMOopciones(selRep);
  selMO = opciones[i];
  renderMO();
  renderResult();
}

// ── RENDER RESULTADO ──
function renderResult(){
  if(!selRep||!selMO) return;
  const box = document.getElementById('resultBox');
  box.classList.add('show');

  const rep = selRep.p;
  const mo  = selMO.val;
  const sub = rep + mo;
  const com = sub * 0.15;
  const tot = sub + com;

  const moOps = getMOopciones(selRep);
  const totMin  = (selRep.p + moOps[0].val) * 1.15;
  const totSug  = (selRep.p + moOps[1].val) * 1.15;
  const totPrem = (selRep.p + moOps[2].val) * 1.15;

  document.getElementById('rbRows').innerHTML = `
    <div class="rb-row"><span class="rl">Repuesto (proveedor)</span><span class="rv">${fmt(rep)}</span></div>
    <div class="rb-row hl"><span class="rl">Mano de obra (${selMO.label})</span><span class="rv">+ ${fmt(mo)}</span></div>
    <div class="rb-row" style="border-top:1px solid rgba(255,255,255,.1);padding-top:7px;margin-top:2px">
      <span class="rl">Subtotal</span><span class="rv">${fmt(sub)}</span>
    </div>
    <div class="rb-row hl"><span class="rl">Comisión 15%</span><span class="rv">+ ${fmt(com)}</span></div>`;

  document.getElementById('rbTotals').innerHTML = `
    <div class="rb-tot"><span class="rt-lbl">Total mínimo</span><span class="rt-val">${fmt(totMin)}</span></div>
    <div class="rb-tot main"><span class="rt-lbl">★ Total sugerido</span><span class="rt-val">${fmt(totSug)}</span></div>
    <div class="rb-tot"><span class="rt-lbl">Total premium</span><span class="rt-val">${fmt(totPrem)}</span></div>`;

  document.getElementById('rbNota').innerHTML =
    `Fórmula: (${fmt(rep)} + ${fmt(mo)}) × 1.15 = ${fmt(tot)}<br>`+
    `Tu ganancia: MO ${fmt(mo)} + comisión ${fmt(com)} = ${fmt(mo+com)}`;
}

// ── STATS ──
function renderStats(){
  const counts = {};
  REPUESTOS.forEach(r=>{ counts[r.b]=(counts[r.b]||0)+1; });
  const total = REPUESTOS.length;
  const marcas = Object.keys(counts).length;
  document.getElementById('statsBar').innerHTML =
    `<div class="stat"><strong>${total.toLocaleString('es-UY')}</strong>repuestos</div>`+
    `<div class="stat"><strong>${marcas}</strong>marcas</div>`+
    Object.entries(counts).sort((a,b)=>b[1]-a[1]).slice(0,6).map(([m,n])=>
      `<div class="stat"><strong>${n}</strong>${m}</div>`).join('');
}

// ── COPY ──
function doCopy(){
  if(!selRep||!selMO) return;
  const rep=selRep.p, mo=selMO.val;
  const sub=rep+mo, com=sub*0.15, tot=sub+com;
  const text=`TecnoJcUy – Presupuesto\n`+
    `Repuesto: ${selRep.n}\n`+
    `Código: ${selRep.c} · Marca: ${selRep.b}\n`+
    `────────────────────────\n`+
    `Repuesto:     ${fmt(rep)}\n`+
    `MO (${selMO.label}): ${fmt(mo)}\n`+
    `Subtotal:     ${fmt(sub)}\n`+
    `Comisión 15%: ${fmt(com)}\n`+
    `────────────────────────\n`+
    `TOTAL:        ${fmt(tot)} ★\n`+
    `────────────────────────\n`+
    `WhatsApp: 093 775 622`;
  navigator.clipboard.writeText(text).then(()=>{
    const btn=event.target; btn.textContent='✓ Copiado';
    setTimeout(()=>btn.textContent='📋 Copiar',2000);
  });
}

// ── CLEAR / RESET ──
function clearSearch(){
  document.getElementById('searchInput').value='';
  document.getElementById('drop').classList.remove('open');
  document.getElementById('clearBtn').classList.remove('show');
}
function clearRepuesto(){
  selRep=null; selMO=null;
  clearSearch();
  document.getElementById('selChip').classList.remove('show');
  document.getElementById('moSection').classList.remove('show');
  document.getElementById('resultBox').classList.remove('show');
}
function resetAll(){
  clearRepuesto();
  tipoFiltro=null;
  renderTipoPills();
}

document.addEventListener('click',e=>{
  if(!e.target.closest('.search-wrap')&&!e.target.closest('.drop'))
    document.getElementById('drop').classList.remove('open');
});

// ── INIT ──
renderTipoPills();
renderStats();
</script>
</body>
</html>
