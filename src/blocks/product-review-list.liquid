{% assign product_obj = closest.product | default: product %}
{% assign product_reviews = product_obj.reviews %}
{% if request.page_type == 'product' and product_page.reviews != blank %}
    {% assign product_reviews = product_page.reviews %}
{% endif %}
{% assign reviews_to_show = block.settings.reviews_to_show | default: 6 %}
{% assign child_blocks = block.children | default: block.blocks %}

<div {{ block.tiendu_attributes }} style="display: contents;">
    {% if product_reviews and product_reviews.size > 0 %}
        {% for review in product_reviews limit: reviews_to_show %}
            {% content_for 'block', id: 'review_card', type: 'product-review', closest.review: review %}
        {% endfor %}
    {% else %}
        {% assign rendered_empty_state = false %}
        {% if child_blocks and child_blocks.size > 0 %}
            {% for child_block in child_blocks %}
                {% if child_block.type == 'product-reviews-empty-state' %}
                    {% assign rendered_empty_state = true %}
                    {% content_for 'block', id: child_block.id, type: child_block.type %}
                    {% break %}
                {% endif %}
            {% endfor %}
        {% endif %}
        {% if rendered_empty_state == false %}
            {% content_for 'block', id: 'empty_state', type: 'product-reviews-empty-state' %}
        {% endif %}
    {% endif %}
</div>

{% schema %}
{
    "name": "product review list",
    "max_blocks": 2,
    "settings": [
        {
            "type": "range",
            "id": "reviews_to_show",
            "label": "Reviews to show",
            "min": 1,
            "max": 12,
            "step": 1,
            "default": 6
        }
    ],
    "blocks": [
        {
            "type": "product-review"
        },
        {
            "type": "product-reviews-empty-state"
        }
    ],
    "presets": [
        {
            "name": "product review list",
            "settings": {
                "reviews_to_show": 6
            },
            "blocks": {
                "review_card": {
                    "type": "product-review",
                    "static": true,
                    "blocks": {
                        "card_layout": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "display: flex; flex-direction: column; gap: 12px; padding: 28px 20px; border-bottom: 1px solid rgba(15, 23, 42, 0.1);",
                                "css_styles_mobile": "padding: 24px 0;"
                            },
                            "blocks": {
                                "top_row": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;",
                                        "css_styles_mobile": "flex-direction: column;"
                                    },
                                    "blocks": {
                                        "author_row": {
                                            "type": "layout",
                                            "settings": {
                                                "css_styles_desktop": "display: flex; align-items: center; gap: 12px; flex-wrap: wrap;"
                                            },
                                            "blocks": {
                                                "author": {
                                                    "type": "product-review__author",
                                                    "blocks": {
                                                        "text": {
                                                            "type": "text",
                                                            "static": true,
                                                            "settings": {
                                                                "bold": true,
                                                                "size_desktop": "base"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "text"
                                                    ]
                                                },
                                                "verified": {
                                                    "type": "layout",
                                                    "settings": {
                                                        "css_styles_desktop": "display: inline-flex; align-items: center; gap: 6px; width: fit-content; padding: 6px 10px; border: 1px solid #99f6e4; border-radius: 9999px; background-color: #ecfdf5; color: #115e59; font-size: 0.8125rem; font-weight: 700; line-height: 1;"
                                                    },
                                                    "blocks": {
                                                        "icon": {
                                                            "type": "icon",
                                                            "settings": {
                                                                "icon": "shield-check",
                                                                "color": "custom",
                                                                "custom_color": "#115e59",
                                                                "size": "sm",
                                                                "stroke_width": "2"
                                                            }
                                                        },
                                                        "text": {
                                                            "type": "text",
                                                            "settings": {
                                                                "text": "Compra verificada",
                                                                "bold": true,
                                                                "size_desktop": "sm"
                                                            }
                                                        }
                                                    },
                                                    "block_order": [
                                                        "icon",
                                                        "text"
                                                    ]
                                                }
                                            },
                                            "block_order": [
                                                "author",
                                                "verified"
                                            ]
                                        },
                                        "rating": {
                                            "type": "product-review__rating",
                                            "blocks": {
                                                "stars": {
                                                    "type": "stars",
                                                    "static": true,
                                                    "settings": {
                                                        "size": "md"
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "stars"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "author_row",
                                        "rating"
                                    ]
                                },
                                "date": {
                                    "type": "product-review__date"
                                },
                                "content": {
                                    "type": "product-review__content",
                                    "blocks": {
                                        "text": {
                                            "type": "text",
                                            "static": true,
                                            "settings": {
                                                "text_type": "paragraph",
                                                "size_desktop": "lg",
                                                "css_styles_desktop": "max-width: 72ch; line-height: 1.55;"
                                            }
                                        }
                                    },
                                    "block_order": [
                                        "text"
                                    ]
                                }
                            },
                            "block_order": [
                                "top_row",
                                "date",
                                "content"
                            ]
                        }
                    },
                    "block_order": [
                        "card_layout"
                    ]
                },
                "empty_state": {
                    "type": "product-reviews-empty-state",
                    "static": true,
                    "blocks": {
                        "layout": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "grid-column: 1 / -1; display: flex; flex-direction: column; align-items: center; gap: 16px; padding: 32px 0; color: #0f172a; text-align: center;"
                            },
                            "blocks": {
                                "icon": {
                                    "type": "icon",
                                    "settings": {
                                        "icon": "messages-square",
                                        "color": "custom",
                                        "custom_color": "#475569",
                                        "size": "lg",
                                        "stroke_width": "1.5"
                                    }
                                },
                                "text": {
                                    "type": "text",
                                    "settings": {
                                        "text": "Este producto aún no tiene reseñas.",
                                        "text_type": "paragraph",
                                        "size_desktop": "xl",
                                        "bold": false
                                    }
                                }
                            },
                            "block_order": [
                                "icon",
                                "text"
                            ]
                        }
                    },
                    "block_order": [
                        "layout"
                    ]
                }
            },
            "block_order": [
                "review_card",
                "empty_state"
            ]
        }
    ]
}
{% endschema %}
