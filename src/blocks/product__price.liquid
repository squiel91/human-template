{% assign product_obj = closest.product | default: product %}
{% assign price_label = blank %}

{% if product_page and product_page.price and product_page.price.price_in_cents != blank %}
    {% capture price_label %}{% if product_page.price.price_is_from %}Desde {% endif %}{{ product_page.price.price_in_cents | money }}{% endcapture %}
{% elsif product_obj and product_obj.variants and product_obj.variants.size > 0 %}
    {% assign min_price = blank %}
    {% assign max_price = blank %}
    {% for variant in product_obj.variants %}
        {% if variant.priceInCents != blank %}
            {% if min_price == blank or variant.priceInCents < min_price %}
                {% assign min_price = variant.priceInCents %}
            {% endif %}
            {% if max_price == blank or variant.priceInCents > max_price %}
                {% assign max_price = variant.priceInCents %}
            {% endif %}
        {% endif %}
    {% endfor %}

    {% if min_price != blank %}
        {% capture price_label %}{% if max_price != blank and max_price > min_price %}Desde {% endif %}{{ min_price | money }}{% endcapture %}
    {% endif %}
{% elsif product_obj and product_obj.basePriceInCents != blank %}
    {% capture price_label %}{{ product_obj.basePriceInCents | money }}{% endcapture %}
{% endif %}

{% assign fallback_text = price_label | default: '$ 1.990' %}

{% if price_label != blank or design_mode or preview_mode %}
    <div data-product-price-wrap {{ block.shopify_attributes }}{% if price_label == blank %} hidden{% endif %}>
        {% if block.blocks and block.blocks.size > 0 %}
            {% content_for 'block', id: 'default-text', type: 'text', default_content: fallback_text, text_id: 'product-price' %}
        {% else %}
            <span id="product-price" style="font-size: 1.5rem; font-weight: 700;">{{ fallback_text }}</span>
        {% endif %}
    </div>
{% endif %}

{% schema %}
{
    "name": "product: Precio",
    "max_blocks": 1,
    "blocks": [
        {
            "type": "text"
        }
    ],
    "presets": [
        {
            "name": "product: Precio",
            "blocks": {
                "default-text": {
                    "type": "text",
                    "static": true,
                    "settings": {
                        "text": "",
                        "text_type": "text",
                        "color": "custom",
                        "custom_color": "#000000",
                        "bold": true,
                        "italic": false,
                        "underline": false,
                        "line_through": false,
                        "size_desktop": "2xl",
                        "size_tablet": "",
                        "size_mobile": "",
                        "css_styles_desktop": "",
                        "css_styles_tablet": "",
                        "css_styles_mobile": ""
                    },
                    "blocks": {}
                }
            },
            "block_order": [
                "default-text"
            ]
        }
    ]
}
{% endschema %}
