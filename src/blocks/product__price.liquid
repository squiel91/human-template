{% assign product_obj = closest.product | default: product %}
{% assign price_label = blank %}
{% assign price_text_id = 'product-price' %}

{% if closest.product != blank or request.page_type != 'product' %}
    {% assign price_text_id = 'product-price-' | append: section.id | append: '-' | append: block.id %}
    {% if product_obj.id != blank %}
        {% assign price_text_id = price_text_id | append: '-' | append: product_obj.id %}
    {% endif %}
{% endif %}

{% if product_page and product_page.price and product_page.price.price_in_cents != blank %}
    {% capture price_label %}{% if product_page.price.price_is_from %}Desde {% endif %}{{ product_page.price.price_in_cents | money }}{% endcapture %}
{% elsif product_obj and product_obj.variants and product_obj.variants.size > 0 %}
    {% assign min_price = blank %}
    {% assign max_price = blank %}
    {% for variant in product_obj.variants %}
        {% if variant.priceInCents != blank %}
            {% if min_price == blank or variant.priceInCents < min_price %}
                {% assign min_price = variant.priceInCents %}
            {% endif %}
            {% if max_price == blank or variant.priceInCents > max_price %}
                {% assign max_price = variant.priceInCents %}
            {% endif %}
        {% endif %}
    {% endfor %}

    {% if min_price != blank %}
        {% capture price_label %}{% if max_price != blank and max_price > min_price %}Desde {% endif %}{{ min_price | money }}{% endcapture %}
    {% endif %}
{% endif %}

{% if price_label == blank and product_obj and product_obj.basePriceInCents != blank %}
    {% capture price_label %}{{ product_obj.basePriceInCents | money }}{% endcapture %}
{% endif %}

{% assign fallback_text = price_label | default: '$ 1.990' %}

{% if price_label != blank or design_mode or preview_mode %}
    <div data-product-price-wrap {{ block.tiendu_attributes }}{% if price_label == blank %} hidden{% endif %}>
        {% if block.children and block.children.size > 0 %}
            {% for child_block in block.children %}
                {% assign child_price_text_id = price_text_id %}
                {% if child_block.id != 'default-text' %}
                    {% assign child_price_text_id = price_text_id | append: '-' | append: child_block.id %}
                {% endif %}
                {% content_for 'block', id: child_block.id, type: child_block.type, default_content: fallback_text, text_id: child_price_text_id %}
            {% endfor %}
        {% else %}
            <span id="{{ price_text_id }}" style="font-size: 1.5rem; font-weight: 700;">{{ fallback_text }}</span>
        {% endif %}
    </div>
{% endif %}

{% schema %}
{
    "name": "product: price",
    "max_blocks": 1,
    "blocks": [
        {
            "type": "text"
        }
    ],
    "presets": [
        {
            "name": "product: price",
            "blocks": {
                "default-text": {
                    "type": "text",
                    "static": true,
                    "settings": {
                        "bold": true,
                        "size_desktop": "2xl"
                    }
                }
            },
            "block_order": [
                "default-text"
            ]
        }
    ]
}
{% endschema %}
