{% assign reviews_quantity = product.reviewsQuantity | default: 0 %}
{% assign fallback_text = 'Reseñas' %}

<div {{ block.tiendu_attributes }}>
    {% content_for 'block', id: 'default-text', type: 'text', default_text: fallback_text %}
</div>

{% schema %}
{
    "name": "text for product reviews",
    "max_blocks": 1,
    "blocks": [
        {
            "type": "text"
        }
    ],
    "presets": [
        {
            "name": "text for product reviews",
            "blocks": {
                "default-text": {
                    "type": "text",
                    "static": true,
                    "settings": {
                        "text_type": "section_title",
                        "bold": true,
                        "size_desktop": "2xl",
                        "size_tablet": "xl",
                        "size_mobile": "lg"
                    }
                }
            },
            "block_order": [
                "default-text"
            ]
        }
    ]
}
{% endschema %}
