{% assign block_render_id = block.render_id %}
{% if block_render_id == blank %}
    {% assign block_render_id = section.id | append: '-' | append: block.id %}
{% endif %}
{% assign input_id = 'tiendu__input-' | append: block_render_id %}
{% assign placeholder = block.settings.placeholder | default: 'tu@email.com' %}
{% assign input_type = block.settings.input_type | default: 'email' %}
{% assign input_rounding = block.settings.rounding | default: 'theme' %}

{% case input_rounding %}
    {% when 'theme' %}
        {% assign input_border_radius = 'var(--button-input-border-radius, 0.375rem)' %}
    {% when 'none' %}
        {% assign input_border_radius = '0' %}
    {% when 'sm' %}
        {% assign input_border_radius = '0.125rem' %}
    {% when 'md' %}
        {% assign input_border_radius = '0.375rem' %}
    {% when 'lg' %}
        {% assign input_border_radius = '0.5rem' %}
    {% when 'xl' %}
        {% assign input_border_radius = '0.75rem' %}
    {% when '2xl' %}
        {% assign input_border_radius = '1rem' %}
    {% when '3xl' %}
        {% assign input_border_radius = '1.5rem' %}
    {% else %}
        {% assign input_border_radius = '9999px' %}
{% endcase %}

<style>
    #{{ input_id }} {
        display: block;
        flex: 1;
        width: 100%;
        min-width: 0;
        box-sizing: border-box;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.2);
        border-radius: {{ input_border_radius }};
        background: white;
        color: inherit;
        font-family: inherit;
        {{ block.settings.css_styles_desktop }}
    }

    @media (width <= 64rem) {
        #{{ input_id }} {
            {{ block.settings.css_styles_tablet }}
        }
    }

    @media (width <= 48rem) {
        #{{ input_id }} {
            {{ block.settings.css_styles_mobile }}
        }
    }

    #{{ input_id }}::placeholder {
        color: #9ca3af;
    }

    #{{ input_id }}:focus {
        outline: 2px solid var(--color-primary, #0000FF);
        outline-offset: 2px;
    }
</style>

<input
    {{ block.tiendu_attributes }}
    id="{{ input_id }}"
    class="t-unformated"
    type="{{ input_type }}"
    name="{{ input_type }}"
    placeholder="{{ placeholder }}"
    required
    aria-label="{{ input_type | capitalize }}"
    data-newsletter-email
>

{% schema %}
{
    "name": "input",
    "settings": [
        {
            "type": "select",
            "id": "input_type",
            "label": "Type",
            "default": "email",
            "options": [
                {
                    "value": "text",
                    "label": "Text"
                },
                {
                    "value": "email",
                    "label": "Email"
                },
                {
                    "value": "password",
                    "label": "Password"
                },
                {
                    "value": "tel",
                    "label": "Tel"
                },
                {
                    "value": "number",
                    "label": "Number"
                },
                {
                    "value": "search",
                    "label": "Search"
                },
                {
                    "value": "url",
                    "label": "URL"
                }
            ]
        },
        {
            "type": "text",
            "id": "placeholder",
            "label": "Placeholder",
            "default": "tu@email.com"
        },
        {
            "type": "select",
            "id": "rounding",
            "label": "Rounding",
            "default": "theme",
            "options": [
                {
                    "value": "theme",
                    "label": "Theme default"
                },
                {
                    "value": "none",
                    "label": "None"
                },
                {
                    "value": "sm",
                    "label": "Sm"
                },
                {
                    "value": "md",
                    "label": "Md"
                },
                {
                    "value": "lg",
                    "label": "Lg"
                },
                {
                    "value": "xl",
                    "label": "Xl"
                },
                {
                    "value": "2xl",
                    "label": "2xl"
                },
                {
                    "value": "3xl",
                    "label": "3xl"
                },
                {
                    "value": "full",
                    "label": "Full"
                }
            ]
        },
        {
            "type": "header",
            "content": "Desktop"
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "CSS styles"
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "CSS styles"
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "CSS styles"
        }
    ],
    "presets": [
        {
            "name": "default",
            "settings": {
                "rounding": "theme"
            }
        }
    ]
}
{% endschema %}
