{% assign link_id = 'tiendu__link-' | append: section.id | append: '-' | append: block.id %}
{% assign open_in_new_tab = block.settings.open_in_new_tab %}

<style>
    #{{ link_id }} {
        display: inline-block;
        text-decoration: none;
        color: inherit;
        {{ block.settings.css_styles_desktop }}
    }

    @media (width <= 64rem) {
        #{{ link_id }} {
            {{ block.settings.css_styles_tablet }}
        }
    }

    @media (width <= 48rem) {
        #{{ link_id }} {
            {{ block.settings.css_styles_mobile }}
        }
    }
</style>

<a
    {{ block.shopify_attributes }}
    id="{{ link_id }}"
    href="{{ block.settings.url | default: '#' }}"
    {% if open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
>
    {% content_for 'blocks' %}
</a>

{% schema %}
{
    "name": "Link",
    "settings": [
        {
            "type": "url",
            "id": "url",
            "label": "URL"
        },
        {
            "type": "checkbox",
            "id": "open_in_new_tab",
            "label": "Abrir en una nueva tab",
            "default": false
        },
        {
            "type": "header",
            "content": "Desktop"
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "Estilos CSS",
            "info": "Los estilos serán heradados para el resto de los tamaños, a menos que se sobre-escriban."
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "Estilos CSS",
            "info": "Los estilos serán heradados para teléfonos, a menos que se sobre-escriban."
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "Estilos CSS",
            "info": "Se aplican unicamente al formato teléfono."
        }
    ],
    "blocks": [
        {
            "type": "@theme"
        }
    ],
    "presets": [
        {
            "name": "Link",
            "blocks": {
                "text": {
                    "type": "text",
                    "settings": {
                        "text": "Nuevo link",
                        "color": "primary",
                        "italic": true
                    }
                }
            },
            "block_order": [
                "text"
            ]
        }
    ]
}
{% endschema %}
