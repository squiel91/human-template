{% assign link_id = 'tiendu__link-' | append: section.id | append: '-' | append: block.id %}
{% assign open_in_new_tab = block.settings.open_in_new_tab %}

<style>
    #{{ link_id }} {
        {{ block.settings.css_styles_desktop }}
    }

    @media (width <= 64rem) {
        #{{ link_id }} {
            {{ block.settings.css_styles_tablet }}
        }
    }

    @media (width <= 48rem) {
        #{{ link_id }} {
            {{ block.settings.css_styles_mobile }}
        }
    }
</style>

<a
    class="tiendu-link"
    {{ block.tiendu_attributes }}
    id="{{ link_id }}"
    href="{{ block.settings.url | default: '#' }}"
    {% if open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
>
    {% content_for 'blocks' %}
</a>

{% schema %}
{
    "name": "Link",
    "settings": [
        {
            "type": "url",
            "id": "url",
            "label": "URL"
        },
        {
            "type": "checkbox",
            "id": "open_in_new_tab",
            "label": "Open in new tab",
            "default": false
        },
        {
            "type": "header",
            "content": "Desktop"
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "CSS styles",
            "info": "Styles will be inherited for other sizes unless overridden."
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "CSS styles",
            "info": "Styles will be inherited for phones unless overridden."
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "CSS styles",
            "info": "Only applied to phone format."
        }
    ],
    "blocks": [
        {
            "type": "@theme"
        }
    ],
    "presets": [
        {
            "name": "default",
            "settings": {
                "css_styles_desktop": ""
            },
            "blocks": {
                "text": {
                    "type": "text",
                    "settings": {
                        "text": "Nuevo link",
                        "color": "custom",
                        "bold": false,
                        "italic": false
                    }
                }
            },
            "block_order": [
                "text"
            ]
        },
        {
            "name": "primary",
            "settings": {
                "css_styles_desktop": "display: flex;\nalign-items: center;\njustify-content: center;\ngap: 8px;\ntext-decoration: none;\ncursor: pointer;\nborder: none;\nfont-family: inherit;\nline-height: 1;\nfont-weight: bold;\ntext-transform: uppercase;\npadding: 0.75rem 1.125rem;\nfont-size: 1rem;\nborder-radius: var(--button-input-border-radius, 0.375rem);\nbackground-color: var(--primary-color);\ncolor: white;\ntransition: opacity 0.2s ease;\n&:hover { opacity: 0.9; }"
            },
            "blocks": {
                "text": {
                    "type": "text",
                    "settings": {
                        "text": "Click me"
                    }
                }
            },
            "block_order": [
                "text"
            ]
        },
        {
            "name": "secondary",
            "settings": {
                "css_styles_desktop": "display: flex;\nalign-items: center;\njustify-content: center;\ngap: 8px;\ntext-decoration: none;\ncursor: pointer;\nborder: none;\nfont-family: inherit;\nline-height: 1;\nfont-weight: bold;\ntext-transform: uppercase;\npadding: 0.75rem 1.125rem;\nfont-size: 1rem;\nborder-radius: var(--button-input-border-radius, 0.375rem);\nbackground-color: transparent;\ncolor: var(--primary-color);\ntransition: background-color 0.2s ease;\n&:hover { background-color: rgba(0, 0, 0, 0.06); }"
            },
            "blocks": {
                "text": {
                    "type": "text",
                    "settings": {
                        "text": "Click me"
                    }
                }
            },
            "block_order": [
                "text"
            ]
        }
    ]
}
{% endschema %}
