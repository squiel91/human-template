{% assign selected_products = section.settings.products %}
{% assign preview_products_count = 4 %}

<div {{ block.shopify_attributes }} style="display: contents;">
    {% if selected_products and selected_products.size > 0 %}
        {% for selected_product in selected_products %}
            {% content_for 'block', id: 'product_card', type: 'product', closest.product: selected_product %}
        {% endfor %}
    {% elsif design_mode or preview_mode %}
        {% for _i in (1..preview_products_count) %}
            {% content_for 'block', id: 'product_card', type: 'product', closest.product: null %}
        {% endfor %}
    {% endif %}
</div>

{% schema %}
{
    "name": "Selected products",
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "product"
        }
    ],
    "presets": [
        {
            "name": "Selected products",
            "blocks": {
                "product_card": {
                    "type": "product",
                    "static": true,
                    "blocks": {
                        "card_wrap": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "display: flex; flex-direction: column; gap: 8px;"
                            },
                            "blocks": {
                                "card_image": {
                                    "type": "product__image",
                                    "settings": {
                                        "transition_to_second_image": true
                                    },
                                    "blocks": {
                                        "default-image": {
                                            "type": "image",
                                            "static": true,
                                            "settings": {
                                                "size": "full",
                                                "image_ratio": "product_default",
                                                "rounding": "theme"
                                            }
                                        }
                                    },
                                    "block_order": [
                                        "default-image"
                                    ]
                                },
                                "card_title": {
                                    "type": "product__title",
                                    "blocks": {
                                        "default-text": {
                                            "type": "text",
                                            "static": true,
                                            "settings": {
                                            }
                                        }
                                    },
                                    "block_order": [
                                        "default-text"
                                    ]
                                },
                                "card_pricing": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;"
                                    },
                                    "blocks": {
                                        "card_price": {
                                            "type": "product__price",
                                            "blocks": {
                                                "default-text": {
                                                    "type": "text",
                                                    "static": true,
                                                    "settings": {
                                                        "bold": true
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "default-text"
                                            ]
                                        },
                                        "card_compare_price": {
                                            "type": "product__compare-price",
                                            "blocks": {
                                                "default-text": {
                                                    "type": "text",
                                                    "static": true,
                                                    "settings": {
                                                        "custom_color": "#94a3b8",
                                                        "line_through": true
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "default-text"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "card_price",
                                        "card_compare_price"
                                    ]
                                }
                            },
                            "block_order": [
                                "card_image",
                                "card_title",
                                "card_pricing"
                            ]
                        }
                    },
                    "block_order": [
                        "card_wrap"
                    ]
                }
            },
            "block_order": [
                "product_card"
            ]
        }
    ]
}
{% endschema %}
