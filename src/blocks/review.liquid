{% assign review_id = 'tiendu__review-' | append: section.id | append: '-' | append: block.id %}
{% assign quote = block.settings.quote %}
{% assign author_name = block.settings.author_name %}
{% assign author_role = block.settings.author_role %}
{% assign card_background = block.settings.background_color | default: 'white' %}
{% assign card_border_radius = block.settings.rounding | default: 'md' %}

{% case card_border_radius %}
    {% when 'none' %}{% assign border_radius = '0' %}
    {% when 'sm' %}{% assign border_radius = '0.25rem' %}
    {% when 'md' %}{% assign border_radius = '0.375rem' %}
    {% when 'lg' %}{% assign border_radius = '0.5rem' %}
    {% when 'xl' %}{% assign border_radius = '0.75rem' %}
    {% when '2xl' %}{% assign border_radius = '1rem' %}
    {% when '3xl' %}{% assign border_radius = '1.5rem' %}
    {% else %}{% assign border_radius = '9999px' %}
{% endcase %}

<style>
    #{{ review_id }} {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding: 24px;
        background-color: {{ card_background }};
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: {{ border_radius }};
        {{ block.settings.css_styles_desktop }}
    }

    #{{ review_id }} .tiendu-review__quote {
        font-size: 1.125rem;
        line-height: 1.6;
        color: inherit;
        margin: 0;
    }

    #{{ review_id }} .tiendu-review__author {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    #{{ review_id }} .tiendu-review__name {
        font-weight: 600;
        font-size: 0.9375rem;
    }

    #{{ review_id }} .tiendu-review__role {
        font-size: 0.875rem;
        opacity: 0.7;
    }

    @media (width <= 64rem) {
        #{{ review_id }} {
            {{ block.settings.css_styles_tablet }}
        }
    }

    @media (width <= 48rem) {
        #{{ review_id }} {
            {{ block.settings.css_styles_mobile }}
        }
    }
</style>

<div {{ block.shopify_attributes }} id="{{ review_id }}" class="tiendu-review">
    <div class="tiendu-review__header">
        {% content_for "blocks" %}
    </div>
    <p class="tiendu-review__quote">&ldquo;{{ quote | escape }}&rdquo;</p>
    <div class="tiendu-review__author">
        <span class="tiendu-review__name">{{ author_name | escape }}</span>
        <span class="tiendu-review__role">{{ author_role | escape }}</span>
    </div>
</div>

{% schema %}
{
    "name": "Reseña",
    "settings": [
        {
            "type": "textarea",
            "id": "quote",
            "label": "Opinión",
            "default": "Excelente servicio y productos de muy buena calidad."
        },
        {
            "type": "text",
            "id": "author_name",
            "label": "Nombre",
            "default": "María G."
        },
        {
            "type": "text",
            "id": "author_role",
            "label": "Rol / Empresa",
            "default": "Cliente"
        },
        {
            "type": "color",
            "id": "background_color",
            "label": "Color de fondo",
            "default": "#ffffff"
        },
        {
            "type": "select",
            "id": "rounding",
            "label": "Redondeado",
            "default": "md",
            "options": [
                { "value": "none", "label": "None" },
                { "value": "sm", "label": "Sm" },
                { "value": "md", "label": "Md" },
                { "value": "lg", "label": "Lg" },
                { "value": "xl", "label": "Xl" },
                { "value": "2xl", "label": "2xl" },
                { "value": "3xl", "label": "3xl" },
                { "value": "full", "label": "Full" }
            ]
        },
        {
            "type": "header",
            "content": "Desktop"
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "Estilos CSS"
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "Estilos CSS"
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "Estilos CSS"
        }
    ],
    "max_blocks": 1,
    "blocks": [
        {
            "type": "stars"
        },
        {
            "type": "text"
        }
    ],
    "presets": [
        {
            "name": "Reseña"
        }
    ]
}
{% endschema %}
