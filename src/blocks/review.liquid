{% assign review_id = 'tiendu__review-' | append: section.id | append: '-' | append: block.id %}
{% assign block_attributes = block.tiendu_attributes | default: block.shopify_attributes %}

<div {{ block_attributes }} id="{{ review_id }}" class="tiendu-review">
    {% content_for 'blocks' %}
</div>

{% schema %}
{
    "name": "review",
    "settings": [],
    "blocks": [
        {
            "type": "@theme"
        }
    ],
    "presets": [
        {
            "name": "default",
            "blocks": {
                "layout_review": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "display: flex; flex-direction: column; gap: 16px; padding: 24px; border: 1px solid #cccccc; border-radius: var(--button-input-border-radius, 0.375rem); background-color: #ffffff;",
                        "css_styles_tablet": "padding: 20px;",
                        "css_styles_mobile": "padding: 16px;"
                    },
                    "blocks": {
                        "stars": {
                            "type": "stars",
                            "settings": {
                                "rating": 5
                            }
                        },
                        "quote": {
                            "type": "text",
                            "settings": {
                                "text": "“Cambiar el tema fue muy simple y nuestra tienda se ve mucho más profesional.”",
                                "text_type": "paragraph",
                                "css_styles_desktop": "font-size: 1.125rem; line-height: 1.6; margin: 0;"
                            }
                        },
                        "author": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "display: flex; flex-direction: column; gap: 4px;"
                            },
                            "blocks": {
                                "author_name": {
                                    "type": "text",
                                    "settings": {
                                        "text": "Sofía P.",
                                        "bold": true,
                                        "css_styles_desktop": "font-size: 0.9375rem;"
                                    }
                                },
                                "author_role": {
                                    "type": "text",
                                    "settings": {
                                        "text": "Dueña, Estudio Verde",
                                        "size_desktop": "sm",
                                        "css_styles_desktop": "opacity: 0.7;"
                                    }
                                }
                            },
                            "block_order": [
                                "author_name",
                                "author_role"
                            ]
                        }
                    },
                    "block_order": [
                        "stars",
                        "quote",
                        "author"
                    ]
                }
            },
            "block_order": [
                "layout_review"
            ]
        }
    ]
}
{% endschema %}
