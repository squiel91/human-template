{% assign product_obj = closest.product | default: product %}
{% assign image_id = 'tiendu__product-image-' | append: section.id | append: '-' | append: block.id %}
{% assign primary_image = product_obj.coverImage %}
{% assign secondary_image = blank %}
{% if product_obj.images and product_obj.images.size > 1 %}
    {% assign secondary_image = product_obj.images[1] %}
{% endif %}
{% assign fallback_alt = product_obj.title | default: 'Imagen del producto' %}
{% assign child_blocks = block.children | default: block.blocks %}
{% assign secondary_image_url = secondary_image.url | default: secondary_image %}
{% assign transition_to_second_image = false %}
{% if block.settings.transition_to_second_image == true or block.settings.transition_to_second_image == 'true' %}
    {% assign transition_to_second_image = true %}
{% endif %}
{% assign product_hover_image = blank %}
{% if transition_to_second_image and secondary_image_url != blank %}
    {% assign product_hover_image = secondary_image %}
{% endif %}

<style>
    #{{ image_id }} {
        display: block;
        {{ block.settings.css_styles_desktop }}
    }

    @media (width <= 64rem) {
        #{{ image_id }} {
            {{ block.settings.css_styles_tablet }}
        }
    }

    @media (width <= 48rem) {
        #{{ image_id }} {
            {{ block.settings.css_styles_mobile }}
        }
    }
</style>

{% if product_obj or design_mode or preview_mode %}
    <div {{ block.tiendu_attributes }} id="{{ image_id }}" class="tiendu-product-image">
        {% if child_blocks and child_blocks.size > 0 %}
            {% for child_block in child_blocks %}
                {% if forloop.index == 1 %}
                    {% if product_hover_image != blank %}
                        {% content_for 'block', id: child_block.id, type: child_block.type, default_image: primary_image, default_alt: fallback_alt, hover_image: product_hover_image %}
                    {% else %}
                        {% content_for 'block', id: child_block.id, type: child_block.type, default_image: primary_image, default_alt: fallback_alt %}
                    {% endif %}
                {% endif %}
            {% endfor %}
        {% else %}
            {% if product_hover_image != blank %}
                {% content_for 'block', id: 'default-image', type: 'image', default_image: primary_image, default_alt: fallback_alt, hover_image: product_hover_image %}
            {% else %}
                {% content_for 'block', id: 'default-image', type: 'image', default_image: primary_image, default_alt: fallback_alt %}
            {% endif %}
        {% endif %}
    </div>
{% endif %}

{% schema %}
{
    "name": "product: image",
    "max_blocks": 1,
    "settings": [
        {
            "type": "checkbox",
            "id": "transition_to_second_image",
            "label": "Transition to second image",
            "info": "On mouse hover, if the product has a second image.",
            "default": true
        },
        {
            "type": "header",
            "content": "Desktop"
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "CSS styles"
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "CSS styles"
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "CSS styles"
        }
    ],
    "blocks": [
        {
            "type": "image"
        }
    ],
    "presets": [
        {
            "name": "product: image",
            "settings": {
                "transition_to_second_image": true
            },
            "blocks": {
                "default-image": {
                    "type": "image",
                    "static": true,
                    "settings": {
                        "size": "full",
                        "image_ratio": "product_default",
                        "rounding": "theme"
                    }
                }
            },
            "block_order": [
                "default-image"
            ]
        }
    ]
}
{% endschema %}
