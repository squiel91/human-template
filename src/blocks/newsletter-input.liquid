{% assign input_id = 'tiendu__newsletter-input-' | append: section.id | append: '-' | append: block.id %}
{% assign placeholder = block.settings.placeholder | default: 'tu@email.com' %}
{% assign input_type = block.settings.input_type | default: 'email' %}

<style>
    #{{ input_id }} {
        display: block;
        flex: 1;
        width: 100%;
        min-width: 0;
        box-sizing: border-box;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.2);
        border-radius: 0.375rem;
        background: white;
        color: inherit;
        font-family: inherit;
        {{ block.settings.css_styles_desktop }}
    }

    @media (width <= 64rem) {
        #{{ input_id }} {
            {{ block.settings.css_styles_tablet }}
        }
    }

    @media (width <= 48rem) {
        #{{ input_id }} {
            {{ block.settings.css_styles_mobile }}
        }
    }

    #{{ input_id }}::placeholder {
        color: #9ca3af;
    }

    #{{ input_id }}:focus {
        outline: 2px solid var(--color-primary, #0000FF);
        outline-offset: 2px;
    }
</style>

<input
    {{ block.shopify_attributes }}
    id="{{ input_id }}"
    type="{{ input_type }}"
    name="{{ input_type }}"
    placeholder="{{ placeholder }}"
    required
    aria-label="{{ input_type | capitalize }}"
    data-newsletter-email
>

{% schema %}
{
    "name": "Input",
    "settings": [
        {
            "type": "select",
            "id": "input_type",
            "label": "Tipo",
            "default": "email",
            "options": [
                { "value": "text", "label": "Text" },
                { "value": "email", "label": "Email" },
                { "value": "password", "label": "Password" },
                { "value": "tel", "label": "Tel" },
                { "value": "number", "label": "Number" },
                { "value": "search", "label": "Search" },
                { "value": "url", "label": "URL" }
            ]
        },
        {
            "type": "text",
            "id": "placeholder",
            "label": "Placeholder",
            "default": "tu@email.com"
        },
        {
            "type": "header",
            "content": "Desktop"
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "Estilos CSS"
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "Estilos CSS"
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "Estilos CSS"
        }
    ],
    "presets": [
        {
            "name": "Input"
        }
    ]
}
{% endschema %}
