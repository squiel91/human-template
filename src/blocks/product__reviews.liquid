{% assign product_obj = closest.product | default: product %}
{% assign average_rating = product_obj.averageRating %}
{% assign reviews_quantity = product_obj.reviewsQuantity | default: 0 %}

{% assign product_reviews = product_obj.reviews %}
{% if request.page_type == 'product' and product_page.reviews != blank %}
    {% assign product_reviews = product_page.reviews %}
{% endif %}

{% if reviews_quantity == 0 or average_rating == blank %}
    {% if product_reviews and product_reviews.size > 0 %}
        {% assign reviews_quantity = product_reviews.size %}
        {% assign total_rating = 0 %}
        {% for review in product_reviews %}
            {% assign total_rating = total_rating | plus: review.rating %}
        {% endfor %}
        {% assign average_rating = total_rating | times: 1.0 | divided_by: reviews_quantity %}
    {% endif %}
{% endif %}

{% assign child_blocks = block.children | default: block.blocks %}
{% assign rating_value = average_rating | default: 0 %}
{% assign can_render_reviews = false %}
{% if product_obj != blank or design_mode or preview_mode %}
    {% assign can_render_reviews = true %}
{% endif %}

{% if can_render_reviews %}
    <div {{ block.tiendu_attributes }}>
        {% if child_blocks and child_blocks.size > 0 %}
            {% for child_block in child_blocks %}
                {% content_for 'block', id: child_block.id, type: child_block.type, default_rating: rating_value, default_reviews_quantity: reviews_quantity %}
            {% endfor %}
        {% else %}
            {% content_for 'block', id: 'default-stars', type: 'stars', default_rating: rating_value, default_reviews_quantity: reviews_quantity %}
        {% endif %}
    </div>
{% endif %}

{% schema %}
{
    "name": "product: reviews",
    "max_blocks": 1,
    "blocks": [
        {
            "type": "stars"
        }
    ],
    "presets": [
        {
            "name": "product: reviews",
            "blocks": {
                "default-stars": {
                    "type": "stars",
                    "static": true,
                    "settings": {
                        "show_value_and_quantity": true
                    }
                }
            },
            "block_order": [
                "default-stars"
            ]
        }
    ]
}
{% endschema %}
