{% assign stars_id = 'tiendu__stars-' | append: section.id | append: '-' | append: block.id %}
{% assign rating = block.settings.rating | default: 5 %}
{% assign star_color = block.settings.color | default: 'primary' %}
{% assign star_size = block.settings.size | default: 'md' %}
{% assign star_count = 5 %}
{% assign fill_percentage = rating | times: 100.0 | divided_by: star_count %}

{% case star_color %}
    {% when 'secondary' %}
        {% assign color_value = settings.secondary_color | default: '#00FF00' %}
    {% when 'accent' %}
        {% assign color_value = settings.accent_color | default: '#FF0000' %}
    {% when 'custom' %}
        {% assign color_value = block.settings.custom_color %}
    {% else %}
        {% assign color_value = settings.primary_color | default: '#0000FF' %}
{% endcase %}

{% case star_size %}
    {% when 'sm' %}
        {% assign size_value = '0.875rem' %}
        {% assign icon_size = 14 %}
    {% when 'lg' %}
        {% assign size_value = '1.5rem' %}
        {% assign icon_size = 24 %}
    {% when 'xl' %}
        {% assign size_value = '2rem' %}
        {% assign icon_size = 32 %}
    {% else %}
        {% assign size_value = '1.125rem' %}
        {% assign icon_size = 18 %}
{% endcase %}

{% capture star_icon %}
    {% render 'icon-star', size: icon_size, stroke_width: 2 %}
{% endcapture %}

<style>
    #{{ stars_id }} {
        display: inline-flex;
        align-items: center;
        color: {{ color_value }};
        line-height: 1;
        {{ block.settings.css_styles_desktop }}
    }

    #{{ stars_id }} .tiendu-stars__container {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.125rem;
    }

    #{{ stars_id }} svg {
        display: block;
        width: {{ size_value }};
        height: {{ size_value }};
        flex: 0 0 auto;
        fill: currentColor;
        stroke: currentColor;
    }

    #{{ stars_id }} .tiendu-stars__background,
    #{{ stars_id }} .tiendu-stars__fill {
        display: inline-flex;
        align-items: center;
        gap: 0.125rem;
    }

    #{{ stars_id }} .tiendu-stars__background {
        color: #d1d5db;
    }

    #{{ stars_id }} .tiendu-stars__fill {
        position: absolute;
        top: 0;
        left: 0;
        overflow: hidden;
        color: inherit;
        width: {{ fill_percentage }}%;
    }

    @media (width <= 64rem) {
        #{{ stars_id }} {
            {{ block.settings.css_styles_tablet }}
        }
    }

    @media (width <= 48rem) {
        #{{ stars_id }} {
            {{ block.settings.css_styles_mobile }}
        }
    }
</style>

<div {{ block.shopify_attributes }} id="{{ stars_id }}" class="tiendu-stars">
    <div class="tiendu-stars__container">
        <div class="tiendu-stars__background" aria-hidden="true">
            {% for i in (1..star_count) %}
                {{ star_icon }}
            {% endfor %}
        </div>
        <div class="tiendu-stars__fill" aria-hidden="true">
            {% for i in (1..star_count) %}
                {{ star_icon }}
            {% endfor %}
        </div>
    </div>
</div>

{% schema %}
{
    "name": "Estrellas",
    "settings": [
        {
            "type": "range",
            "id": "rating",
            "label": "Calificación",
            "min": 0,
            "max": 5,
            "step": 0.1,
            "default": 5
        },
        {
            "type": "select",
            "id": "color",
            "label": "Color",
            "default": "primary",
            "options": [
                {
                    "value": "primary",
                    "label": "Primario"
                },
                {
                    "value": "secondary",
                    "label": "Secundario"
                },
                {
                    "value": "accent",
                    "label": "Acento"
                },
                {
                    "value": "custom",
                    "label": "Personalizado"
                }
            ]
        },
        {
            "type": "color",
            "id": "custom_color",
            "label": "Color personalizado"
        },
        {
            "type": "select",
            "id": "size",
            "label": "Tamaño",
            "default": "md",
            "options": [
                {
                    "value": "sm",
                    "label": "Sm"
                },
                {
                    "value": "md",
                    "label": "Md"
                },
                {
                    "value": "lg",
                    "label": "Lg"
                },
                {
                    "value": "xl",
                    "label": "Xl"
                }
            ]
        },
        {
            "type": "header",
            "content": "Desktop"
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "Estilos CSS"
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "Estilos CSS"
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "Estilos CSS"
        }
    ],
    "presets": [
        {
            "name": "Estrellas"
        }
    ]
}
{% endschema %}
