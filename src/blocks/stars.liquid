{% assign stars_id = 'tiendu__stars-' | append: section.id | append: '-' | append: block.id %}
{% assign rating = default_rating %}
{% if rating == blank %}
    {% assign rating = block.settings.rating | default: 5 %}
{% endif %}
{% assign reviews_quantity = default_reviews_quantity | default: 0 %}
{% assign star_color = block.settings.color | default: 'primary' %}
{% assign star_size = block.settings.size | default: 'md' %}
{% assign show_value_and_quantity = false %}
{% if block.settings.show_value_and_quantity == true or block.settings.show_value_and_quantity == 'true' %}
    {% assign show_value_and_quantity = true %}
{% endif %}
{% assign star_count = 5 %}
{% assign fill_percentage = rating | times: 100.0 | divided_by: star_count %}
{% assign rating_label = rating | round: 1 %}

{% case star_color %}
    {% when 'secondary' %}
        {% assign color_value = settings.secondary_color | default: '#00FF00' %}
    {% when 'accent' %}
        {% assign color_value = settings.accent_color | default: '#FF0000' %}
    {% when 'custom' %}
        {% assign color_value = block.settings.custom_color %}
    {% else %}
        {% assign color_value = settings.primary_color | default: '#0000FF' %}
{% endcase %}

{% case star_size %}
    {% when 'sm' %}
        {% assign size_value = '0.875rem' %}
        {% assign icon_size = 14 %}
    {% when 'lg' %}
        {% assign size_value = '1.5rem' %}
        {% assign icon_size = 24 %}
    {% when 'xl' %}
        {% assign size_value = '2rem' %}
        {% assign icon_size = 32 %}
    {% else %}
        {% assign size_value = '1.125rem' %}
        {% assign icon_size = 18 %}
{% endcase %}

{% capture star_icon %}
    {% render 'icon-star', size: icon_size, stroke_width: 2 %}
{% endcapture %}

<style>
    #{{ stars_id }} {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        line-height: 1;
        {{ block.settings.css_styles_desktop }}
    }

    #{{ stars_id }} .tiendu-stars__container {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.125rem;
        color: {{ color_value }};
    }

    #{{ stars_id }} svg {
        display: block;
        width: {{ size_value }};
        height: {{ size_value }};
        flex: 0 0 auto;
        fill: currentColor;
        stroke: currentColor;
    }

    #{{ stars_id }} .tiendu-stars__background,
    #{{ stars_id }} .tiendu-stars__fill {
        display: inline-flex;
        align-items: center;
        gap: 0.125rem;
    }

    #{{ stars_id }} .tiendu-stars__background {
        color: #d1d5db;
    }

    #{{ stars_id }} .tiendu-stars__fill {
        position: absolute;
        top: 0;
        left: 0;
        overflow: hidden;
        color: inherit;
        width: {{ fill_percentage }}%;
    }

    #{{ stars_id }} .tiendu-stars__value {
        display: inline-flex;
        align-items: center;
        font-size: 0.875rem;
        text-align: center;
        white-space: nowrap;
    }

    @media (width <= 64rem) {
        #{{ stars_id }} {
            {{ block.settings.css_styles_tablet }}
        }
    }

    @media (width <= 48rem) {
        #{{ stars_id }} {
            {{ block.settings.css_styles_mobile }}
        }
    }
</style>

<div {{ block.tiendu_attributes }} id="{{ stars_id }}" class="tiendu-stars">
    <div class="tiendu-stars__container">
        <div class="tiendu-stars__background" aria-hidden="true">
            {% for i in (1..star_count) %}
                {{ star_icon }}
            {% endfor %}
        </div>
        <div class="tiendu-stars__fill" aria-hidden="true">
            {% for i in (1..star_count) %}
                {{ star_icon }}
            {% endfor %}
        </div>
    </div>
    {% if show_value_and_quantity %}
        <span class="tiendu-stars__value">{{ rating_label }} ({{ reviews_quantity }})</span>
    {% endif %}
</div>

{% schema %}
{
    "name": "stars",
    "settings": [
        {
            "type": "range",
            "id": "rating",
            "label": "Rating",
            "min": 0,
            "max": 5,
            "step": 0.1,
            "default": 5
        },
        {
            "type": "select",
            "id": "color",
            "label": "Color",
            "default": "primary",
            "options": [
                {
                    "value": "primary",
                    "label": "Primary"
                },
                {
                    "value": "secondary",
                    "label": "Secondary"
                },
                {
                    "value": "accent",
                    "label": "Accent"
                },
                {
                    "value": "custom",
                    "label": "Custom"
                }
            ]
        },
        {
            "type": "color",
            "id": "custom_color",
            "label": "Custom color"
        },
        {
            "type": "select",
            "id": "size",
            "label": "Size",
            "default": "md",
            "options": [
                {
                    "value": "sm",
                    "label": "Sm"
                },
                {
                    "value": "md",
                    "label": "Md"
                },
                {
                    "value": "lg",
                    "label": "Lg"
                },
                {
                    "value": "xl",
                    "label": "Xl"
                }
            ]
        },
        {
            "type": "checkbox",
            "id": "show_value_and_quantity",
            "label": "Show value and quantity",
            "default": false
        },
        {
            "type": "header",
            "content": "Desktop"
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "CSS styles"
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "CSS styles"
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "CSS styles"
        }
    ],
    "presets": [
        {
            "name": "stars"
        }
    ]
}
{% endschema %}
