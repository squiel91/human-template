{% assign block_attributes = block.tiendu_attributes %}

<article class="tiendu-carousel__slide" data-tiendu-carousel-slide aria-hidden="false" {{ block_attributes }}>
    {% if block.blocks and block.blocks.size > 0 %}
        <div class="tiendu-carousel__slide-content">
            {% content_for 'blocks' %}
        </div>
    {% endif %}
</article>

{% schema %}
{
    "name": "slide",
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "default",
            "blocks": {
                "content": {
                    "type": "layout",
                    "settings": {
                        "background_color_desktop": "#f5efe8",
                        "css_styles_desktop": "position: relative; display: flex; align-items: flex-end; min-height: inherit; padding: 0 var(--container-horizontal-padding, 8px);"
                    },
                    "blocks": {
                        "overlay": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0, 0, 0, 0), rgba(0, 0, 0, .75)); z-index: 0;"
                            }
                        },
                        "inner": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "position: relative; z-index: 1; display: flex; flex-direction: column; justify-content: flex-end; align-items: flex-start; gap: 16px; min-height: inherit; width: 100%; max-width: var(--container-max-width, 1024px); margin: 0 auto; padding: 48px 0;",
                                "css_styles_tablet": "padding: 40px 0;",
                                "css_styles_mobile": "padding: 32px 0;"
                            },
                            "blocks": {
                                "title": {
                                    "type": "text",
                                    "settings": {
                                        "text": "Título del slide",
                                        "text_type": "section_title",
                                        "color": "custom",
                                        "custom_color": "#FFFFFF",
                                        "bold": true,
                                        "size_desktop": "5xl",
                                        "size_tablet": "3xl",
                                        "size_mobile": "2xl",
                                        "css_styles_desktop": "max-width: 48ch;"
                                    }
                                },
                                "description": {
                                    "type": "text",
                                    "settings": {
                                        "text": "Descripción del slide para acompañar el mensaje principal.",
                                        "text_type": "paragraph",
                                        "color": "custom",
                                        "custom_color": "#FFFFFF",
                                        "size_desktop": "lg",
                                        "size_tablet": "base",
                                        "css_styles_desktop": "max-width: 60ch; line-height: 1.6;"
                                    }
                                },
                                "cta": {
                                    "type": "link",
                                    "preset": "primary"
                                }
                            },
                            "block_order": [
                                "title",
                                "description",
                                "cta"
                            ]
                        }
                    },
                    "block_order": [
                        "overlay",
                        "inner"
                    ]
                }
            },
            "block_order": [
                "content"
            ]
        }
    ]
}
{% endschema %}
