{% assign sort_id = 'tiendu__collection-sort-' | append: section.id | append: '-' | append: block.id %}
{% assign current_sort = collection.sort_by | default: collection.default_sort_by %}

<style>
    #{{ sort_id }} {
        position: relative;
        display: inline-flex;
        align-items: center;
        width: 100%;
        max-width: 16rem;
    }

    #{{ sort_id }} select {
        flex: 1;
        width: 100%;
        min-width: 0;
        box-sizing: border-box;
        padding: 0.75rem 2.5rem 0.75rem 1rem;
        font-size: 1rem;
        font-family: inherit;
        border: 1px solid rgba(0, 0, 0, 0.2);
        border-radius: var(--button-input-border-radius, 0.375rem);
        background: white;
        color: inherit;
        appearance: none;
        -webkit-appearance: none;
        cursor: pointer;
        {{ block.settings.css_styles_desktop }}
    }

    @media (width <= 64rem) {
        #{{ sort_id }} select {
            {{ block.settings.css_styles_tablet }}
        }
    }

    @media (width <= 48rem) {
        #{{ sort_id }} select {
            {{ block.settings.css_styles_mobile }}
        }
    }

    #{{ sort_id }} select:focus {
        outline: 2px solid var(--color-primary, #0000FF);
        outline-offset: 2px;
    }

    #{{ sort_id }} .tiendu-collection-sort__icon {
        position: absolute;
        right: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: inherit;
        opacity: 0.6;
    }
</style>

<div id="{{ sort_id }}" data-collection-sort>
    <select
        {{ block.tiendu_attributes }}
        name="sort_by"
        aria-label="Ordenar productos"
    >
        {% for option in collection.sort_options %}
            <option
                value="{{ option.value }}"
                {% if current_sort == option.value %}selected{% endif %}
            >
                {{ option.name }}
            </option>
        {% endfor %}
    </select>
    <span class="tiendu-collection-sort__icon" aria-hidden="true">
        {% render 'icon-chevron-down', size: 16, stroke_width: 2 %}
    </span>
</div>

{% schema %}
{
    "name": "Collection sort",
    "settings": [
        {
            "type": "header",
            "content": "Desktop"
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "CSS styles",
            "info": "Styles will be inherited for other sizes unless overridden."
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "CSS styles",
            "info": "Styles will be inherited for phones unless overridden."
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "CSS styles",
            "info": "Only applied to phone format."
        }
    ],
    "presets": [
        {
            "name": "Collection sort"
        }
    ]
}
{% endschema %}
