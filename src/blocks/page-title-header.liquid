{% assign fallback_text = page.title | default: 'Título de la página' %}

<div class="tiendu-page-title-header" {{ block.shopify_attributes }}>
    {% content_for 'block', type: 'text', id: 'page-heading', default_text: fallback_text %}
</div>

{% schema %}
{
    "name": "Título de la página",
    "max_blocks": 1,
    "blocks": [
        {
            "type": "text"
        }
    ],
    "presets": [
        {
            "name": "Título de la página",
            "blocks": {
                "page-heading": {
                    "type": "text",
                    "static": true,
                    "settings": {
                        "text_type": "page_title",
                        "custom_color": "#000000",
                        "bold": true,
                        "size_desktop": "4xl"
                    }
                }
            },
            "block_order": [
                "page-heading"
            ]
        }
    ]
}
{% endschema %}
