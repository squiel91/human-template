<form class="tiendu-newsletter-form" data-newsletter-form novalidate>
    {% content_for "blocks" %}
</form>

{% schema %}
{
    "name": "Formulario newsletter",
    "settings": [],
    "blocks": [
        {
            "type": "layout"
        }
    ],
    "presets": [
        {
            "name": "Formulario newsletter",
            "blocks": {
                "form_layout": {
                    "type": "layout",
                    "settings": {
                        "image_desktop": "",
                        "background_color_desktop": "",
                        "css_styles_desktop": "display: flex; align-items: stretch; gap: 8px; width: 100%; max-width: 480px;",
                        "image_tablet": "",
                        "background_color_tablet": "",
                        "css_styles_tablet": "",
                        "image_mobile": "",
                        "background_color_mobile": "",
                        "css_styles_mobile": ""
                    },
                    "blocks": {
                        "email_input": {
                            "type": "newsletter-input",
                            "settings": {
                                "placeholder": "tu@email.com",
                                "css_styles_desktop": "",
                                "css_styles_tablet": "",
                                "css_styles_mobile": ""
                            },
                            "blocks": {}
                        },
                        "submit_button": {
                            "type": "button",
                            "settings": {
                                "text": "Suscribirme",
                                "action": "submit",
                                "color": "primary",
                                "size": "md",
                                "variant": "primary",
                                "rounding": "md",
                                "css_styles_desktop": "",
                                "css_styles_tablet": "",
                                "css_styles_mobile": ""
                            },
                            "blocks": {}
                        }
                    },
                    "block_order": [
                        "email_input",
                        "submit_button"
                    ]
                }
            },
            "block_order": [
                "form_layout"
            ]
        }
    ]
}
{% endschema %}
