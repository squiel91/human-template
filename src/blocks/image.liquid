{% assign image_id = 'tiendu__image-' | append: section.id | append: '-' | append: block.id %}
{% assign configured_image = block.settings.image %}
{% assign image_url = configured_image.url | default: configured_image | default: default_image.url | default: default_image %}
{% assign image_rounding = block.settings.rounding | default: 'none' %}
{% assign image_ratio_setting = block.settings.image_ratio | default: 'square' %}
{% if image_ratio_setting == 'product_default' %}
    {% assign image_ratio = settings.product_image_ratio | default: 'square' %}
{% elsif image_ratio_setting == 'collection_default' %}
    {% assign image_ratio = settings.collection_image_ratio | default: 'square' %}
{% else %}
    {% assign image_ratio = image_ratio_setting %}
{% endif %}
{% assign image_alt = block.settings.alt | default: configured_image.alt | default: default_image.alt | default: default_alt %}
{% assign hover_image_url = '' %}
{% if hover_image != blank and hover_image.url != blank %}
    {% assign hover_image_url = hover_image.url | strip %}
{% endif %}
{% assign hover_image_alt = hover_image.alt | default: image_alt %}
{% assign image_size = block.settings.size | default: 'full' %}
{% assign placeholder_image = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 400'%3E%3Crect width='400' height='400' fill='%23e5e7eb'/%3E%3Cpath d='M120 280l55-70 45 55 35-45 65 60H120z' fill='%239ca3af'/%3E%3Ccircle cx='155' cy='145' r='28' fill='%239ca3af'/%3E%3C/svg%3E" %}

{% case image_rounding %}
    {% when 'theme' %}
        {% assign image_border_radius = 'var(--product-image-border-radius, 0)' %}
    {% when 'none' %}
        {% assign image_border_radius = '0' %}
    {% when 'sm' %}
        {% assign image_border_radius = '0.125rem' %}
    {% when 'md' %}
        {% assign image_border_radius = '0.375rem' %}
    {% when 'lg' %}
        {% assign image_border_radius = '0.5rem' %}
    {% when 'xl' %}
        {% assign image_border_radius = '0.75rem' %}
    {% when '2xl' %}
        {% assign image_border_radius = '1rem' %}
    {% when '3xl' %}
        {% assign image_border_radius = '1.5rem' %}
    {% else %}
        {% assign image_border_radius = '9999px' %}
{% endcase %}

{% case image_ratio %}
    {% when 'portrait' %}
        {% assign image_aspect_ratio = '3 / 4' %}
    {% when 'landscape' %}
        {% assign image_aspect_ratio = '4 / 3' %}
    {% when 'wide' %}
        {% assign image_aspect_ratio = '16 / 9' %}
    {% when 'ultrawide' %}
        {% assign image_aspect_ratio = '21 / 9' %}
    {% else %}
        {% assign image_aspect_ratio = '1 / 1' %}
{% endcase %}

{% case image_size %}
    {% when '1/5' %}
        {% assign image_width = '20%' %}
    {% when '1/4' %}
        {% assign image_width = '25%' %}
    {% when '1/3' %}
        {% assign image_width = '33.333333%' %}
    {% when '2/5' %}
        {% assign image_width = '40%' %}
    {% when '1/2' %}
        {% assign image_width = '50%' %}
    {% when '3/5' %}
        {% assign image_width = '60%' %}
    {% when '2/3' %}
        {% assign image_width = '66.666667%' %}
    {% when '3/4' %}
        {% assign image_width = '75%' %}
    {% when '4/5' %}
        {% assign image_width = '80%' %}
    {% else %}
        {% assign image_width = '100%' %}
{% endcase %}

<style>
    #{{ image_id }} {
        position: relative;
        display: block;
        width: {{ image_width }};
        max-width: 100%;
        overflow: hidden;
        border-radius: {{ image_border_radius }};
    }

    #{{ image_id }} .tiendu-image__img {
        display: block;
        position: relative;
        z-index: 0;
        width: 100%;
        max-width: 100%;
        object-position: center;
        {% if image_ratio == 'proportional' %}
            height: auto;
            object-fit: contain;
        {% else %}
            height: 100%;
            object-fit: cover;
        {% endif %}
    }

    {% if image_ratio != 'proportional' %}
        #{{ image_id }} {
            aspect-ratio: {{ image_aspect_ratio }};
        }
    {% endif %}

</style>

<span
    {{ block.shopify_attributes }}
    id="{{ image_id }}"
    class="tiendu-image"
    >
    <img
        class="tiendu-image__img"
        src="{{ image_url | default: placeholder_image }}"
        alt="{{ image_alt | escape }}"
        loading="lazy"
    >
    {% if hover_image_url != '' %}
        <img
            class="tiendu-image__hover-image"
            src="{{ hover_image_url | escape_attr }}"
            alt="{{ hover_image_alt | escape }}"
            aria-hidden="true"
            loading="lazy"
            decoding="async"
            fetchpriority="low"
        >
    {% endif %}
</span>

