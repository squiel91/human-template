{% assign image_id = 'tiendu__image-' | append: section.id | append: '-' | append: block.id %}
{% assign image_url = block.settings.image %}
{% assign image_rounding = block.settings.rounding | default: 'none' %}
{% assign image_ratio = block.settings.image_ratio | default: 'square' %}
{% assign image_alt = block.settings.alt %}
{% assign image_size = block.settings.size | default: 'full' %}
{% assign placeholder_image = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 400'%3E%3Crect width='400' height='400' fill='%23e5e7eb'/%3E%3Cpath d='M120 280l55-70 45 55 35-45 65 60H120z' fill='%239ca3af'/%3E%3Ccircle cx='155' cy='145' r='28' fill='%239ca3af'/%3E%3C/svg%3E" %}

{% case image_rounding %}
    {% when 'none' %}
        {% assign image_border_radius = '0' %}
    {% when 'sm' %}
        {% assign image_border_radius = '0.125rem' %}
    {% when 'md' %}
        {% assign image_border_radius = '0.375rem' %}
    {% when 'lg' %}
        {% assign image_border_radius = '0.5rem' %}
    {% when 'xl' %}
        {% assign image_border_radius = '0.75rem' %}
    {% when '2xl' %}
        {% assign image_border_radius = '1rem' %}
    {% when '3xl' %}
        {% assign image_border_radius = '1.5rem' %}
    {% else %}
        {% assign image_border_radius = '9999px' %}
{% endcase %}

{% case image_ratio %}
    {% when 'portrait' %}
        {% assign image_aspect_ratio = '3 / 4' %}
    {% when 'landscape' %}
        {% assign image_aspect_ratio = '4 / 3' %}
    {% when 'wide' %}
        {% assign image_aspect_ratio = '16 / 9' %}
    {% when 'ultrawide' %}
        {% assign image_aspect_ratio = '21 / 9' %}
    {% else %}
        {% assign image_aspect_ratio = '1 / 1' %}
{% endcase %}

{% case image_size %}
    {% when '1/5' %}
        {% assign image_width = '20%' %}
    {% when '1/4' %}
        {% assign image_width = '25%' %}
    {% when '1/3' %}
        {% assign image_width = '33.333333%' %}
    {% when '2/5' %}
        {% assign image_width = '40%' %}
    {% when '1/2' %}
        {% assign image_width = '50%' %}
    {% when '3/5' %}
        {% assign image_width = '60%' %}
    {% when '2/3' %}
        {% assign image_width = '66.666667%' %}
    {% when '3/4' %}
        {% assign image_width = '75%' %}
    {% when '4/5' %}
        {% assign image_width = '80%' %}
    {% else %}
        {% assign image_width = '100%' %}
{% endcase %}

<style>
    #{{ image_id }} {
        display: block;
        width: {{ image_width }};
        max-width: 100%;
        overflow: hidden;
        border-radius: {{ image_border_radius }};
        object-position: center;
        {% if image_ratio == 'proportional' %}
            height: auto;
            object-fit: contain;
        {% else %}
            height: 100%;
            object-fit: cover;
        {% endif %}
    }

    {% if image_ratio != 'proportional' %}
        #{{ image_id }} {
            aspect-ratio: {{ image_aspect_ratio }};
        }
    {% endif %}
</style>

<img
    {{ block.shopify_attributes }}
    id="{{ image_id }}"
    src="{{ image_url | default: placeholder_image }}"
    alt="{{ image_alt | escape }}"
>

{% schema %}
{
    "name": "Imagen",
    "settings": [
        {
            "type": "image",
            "id": "image",
            "label": "Imagen"
        },
        {
            "type": "select",
            "id": "size",
            "label": "Tamano",
            "default": "full",
            "options": [
                { "value": "1/5", "label": "1/5" },
                { "value": "1/4", "label": "1/4" },
                { "value": "1/3", "label": "1/3" },
                { "value": "2/5", "label": "2/5" },
                { "value": "1/2", "label": "1/2" },
                { "value": "3/5", "label": "3/5" },
                { "value": "2/3", "label": "2/3" },
                { "value": "3/4", "label": "3/4" },
                { "value": "4/5", "label": "4/5" },
                { "value": "full", "label": "Completa" }
            ]
        },
        {
            "type": "select",
            "id": "image_ratio",
            "label": "Ratio",
            "default": "square",
            "options": [
                { "value": "proportional", "label": "Proporción de la imagen" },
                { "value": "square", "label": "Cuadrada (1:1)" },
                { "value": "portrait", "label": "Vertical (3:4)" },
                { "value": "landscape", "label": "Horizontal (4:3)" },
                { "value": "wide", "label": "Panorámica (16:9)" },
                { "value": "ultrawide", "label": "Ultrawide (21:9)" }
            ]
        },
        {
            "type": "select",
            "id": "rounding",
            "label": "Redondeado",
            "default": "none",
            "options": [
                { "value": "none", "label": "None" },
                { "value": "sm", "label": "Sm" },
                { "value": "md", "label": "Md" },
                { "value": "lg", "label": "Lg" },
                { "value": "xl", "label": "Xl" },
                { "value": "2xl", "label": "2xl" },
                { "value": "3xl", "label": "3xl" },
                { "value": "full", "label": "Full" }
            ]
        },
        {
            "type": "text",
            "id": "alt",
            "label": "Alt",
            "info": "Si se deja vacio, no se agrega alt."
        }
    ],
    "presets": [
        {
            "name": "Imagen"
        }
    ]
}
{% endschema %}
