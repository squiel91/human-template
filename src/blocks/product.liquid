{% assign product_object = closest.product | default: product %}
{% assign product_url = product_object.url | default: '#' %}

{% assign product_rounding = block.settings.rounding | default: 'theme' %}

{% case product_rounding %}
    {% when 'theme' %}
        {% assign product_border_radius = 'var(--product-image-border-radius, 0)' %}
    {% when 'none' %}
        {% assign product_border_radius = '0' %}
    {% when 'sm' %}
        {% assign product_border_radius = '0.125rem' %}
    {% when 'md' %}
        {% assign product_border_radius = '0.375rem' %}
    {% when 'lg' %}
        {% assign product_border_radius = '0.5rem' %}
    {% when 'xl' %}
        {% assign product_border_radius = '0.75rem' %}
    {% when '2xl' %}
        {% assign product_border_radius = '1rem' %}
    {% when '3xl' %}
        {% assign product_border_radius = '1.5rem' %}
    {% else %}
        {% assign product_border_radius = '9999px' %}
{% endcase %}

<a
    {{ block.shopify_attributes }}
    href="{{ product_url }}"
    style="
        display: flex;
        flex-direction: column;
        gap: 8px;
        text-decoration: none;
        color: inherit;
        border-radius: {{ product_border_radius }};
        {{ block.settings.css_styles_desktop }}
    "
>
    {% if block.blocks and block.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Add blocks to the product (title, price, etc.).</div>
    {% endif %}
</a>

{% schema %}
{
    "name": "Product",
    "settings": [
        {
            "type": "select",
            "id": "rounding",
            "label": "Rounding",
            "default": "theme",
            "options": [
                {
                    "value": "theme",
                    "label": "Theme default"
                },
                {
                    "value": "none",
                    "label": "None"
                },
                {
                    "value": "sm",
                    "label": "Sm"
                },
                {
                    "value": "md",
                    "label": "Md"
                },
                {
                    "value": "lg",
                    "label": "Lg"
                },
                {
                    "value": "xl",
                    "label": "Xl"
                },
                {
                    "value": "2xl",
                    "label": "2xl"
                },
                {
                    "value": "3xl",
                    "label": "3xl"
                },
                {
                    "value": "full",
                    "label": "Full"
                }
            ]
        },
        {
            "type": "header",
            "content": "Desktop"
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "CSS styles"
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "CSS styles"
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "CSS styles"
        }
    ],
    "blocks": [
        {
            "type": "@theme"
        }
    ],
    "presets": [
        {
            "name": "Product",
            "blocks": {
                "card_wrap": {
                    "type": "layout",
                    "settings": {
                        "css_styles_desktop": "display: flex; flex-direction: column; gap: 8px;"
                    },
                    "blocks": {
                        "card_image": {
                            "type": "product__image",
                            "settings": {
                                "transition_to_second_image": true
                            },
                            "blocks": {
                                "default-image": {
                                    "type": "image",
                                    "static": true,
                                    "settings": {
                                        "size": "full",
                                        "image_ratio": "product_default",
                                        "rounding": "theme"
                                    }
                                }
                            },
                            "block_order": [
                                "default-image"
                            ]
                        },
                        "card_title": {
                            "type": "product__title",
                            "blocks": {
                                "default-text": {
                                    "type": "text",
                                    "static": true,
                                    "settings": {}
                                }
                            },
                            "block_order": [
                                "default-text"
                            ]
                        },
                        "card_reviews": {
                            "type": "product__reviews",
                            "blocks": {
                                "default-stars": {
                                    "type": "stars",
                                    "static": true,
                                    "settings": {
                                        "show_value_and_quantity": true
                                    }
                                }
                            },
                            "block_order": [
                                "default-stars"
                            ]
                        },
                        "card_pricing": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;"
                            },
                            "blocks": {
                                "card_price": {
                                    "type": "product__price",
                                    "blocks": {
                                        "default-text": {
                                            "type": "text",
                                            "static": true,
                                            "settings": {
                                                "bold": true
                                            }
                                        }
                                    },
                                    "block_order": [
                                        "default-text"
                                    ]
                                },
                                "card_compare_price": {
                                    "type": "product__compare-price",
                                    "blocks": {
                                        "default-text": {
                                            "type": "text",
                                            "static": true,
                                            "settings": {
                                                "custom_color": "#94a3b8",
                                                "line_through": true
                                            }
                                        }
                                    },
                                    "block_order": [
                                        "default-text"
                                    ]
                                }
                            },
                            "block_order": [
                                "card_price",
                                "card_compare_price"
                            ]
                        }
                    },
                    "block_order": [
                        "card_image",
                        "card_title",
                        "card_reviews",
                        "card_pricing"
                    ]
                }
            },
            "block_order": [
                "card_wrap"
            ]
        }
    ]
}
{% endschema %}
