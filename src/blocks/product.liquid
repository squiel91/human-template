{% assign product_object = closest.product | default: product %}
{% assign product_url = product_object.url | default: '#' %}

{% assign product_rounding = block.settings.rounding | default: 'theme' %}

{% case product_rounding %}
    {% when 'theme' %}
        {% assign product_border_radius = 'var(--product-image-border-radius, 0)' %}
    {% when 'none' %}
        {% assign product_border_radius = '0' %}
    {% when 'sm' %}
        {% assign product_border_radius = '0.125rem' %}
    {% when 'md' %}
        {% assign product_border_radius = '0.375rem' %}
    {% when 'lg' %}
        {% assign product_border_radius = '0.5rem' %}
    {% when 'xl' %}
        {% assign product_border_radius = '0.75rem' %}
    {% when '2xl' %}
        {% assign product_border_radius = '1rem' %}
    {% when '3xl' %}
        {% assign product_border_radius = '1.5rem' %}
    {% else %}
        {% assign product_border_radius = '9999px' %}
{% endcase %}

<a
    {{ block.shopify_attributes }}
    href="{{ product_url }}"
    style="
        display: flex;
        flex-direction: column;
        gap: 8px;
        text-decoration: none;
        color: inherit;
        border-radius: {{ product_border_radius }};
        {{ block.settings.css_styles_desktop }}
    "
>
    {% if block.blocks and block.blocks.size > 0 %}
        {% content_for 'blocks' %}
    {% elsif design_mode or preview_mode %}
        <div>Agrega bloques al producto (título, precio, etc.).</div>
    {% endif %}
</a>

{% schema %}
{
    "name": "Producto",
    "settings": [
        {
            "type": "select",
            "id": "rounding",
            "label": "Redondeado",
            "default": "theme",
            "options": [
                {
                    "value": "theme",
                    "label": "Defecto del tema"
                },
                {
                    "value": "none",
                    "label": "None"
                },
                {
                    "value": "sm",
                    "label": "Sm"
                },
                {
                    "value": "md",
                    "label": "Md"
                },
                {
                    "value": "lg",
                    "label": "Lg"
                },
                {
                    "value": "xl",
                    "label": "Xl"
                },
                {
                    "value": "2xl",
                    "label": "2xl"
                },
                {
                    "value": "3xl",
                    "label": "3xl"
                },
                {
                    "value": "full",
                    "label": "Full"
                }
            ]
        },
        {
            "type": "header",
            "content": "Desktop"
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "Estilos CSS"
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "Estilos CSS"
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "Estilos CSS"
        }
    ],
    "blocks": [
        {
            "type": "@theme"
        }
    ],
    "presets": [
        {
            "name": "Producto"
        }
    ]
}
{% endschema %}
