{% assign products_per_page = section.settings.products_to_show | default: block.settings.products_per_page | default: 12 %}

<div {{ block.shopify_attributes }} style="display: contents;">
    {% if request.page_type == 'collection' and collection != blank %}
        {% paginate collection.products by products_per_page %}
            {% for product in collection.products %}
                {% content_for 'block', id: 'product_card', type: 'product', closest.product: product %}
            {% endfor %}

            {% if block.settings.show_pagination and paginate.pages > 1 %}
                <nav class="tiendu-pagination" aria-label="Paginación de productos">
                    {{ paginate | default_pagination }}
                </nav>
            {% endif %}
        {% endpaginate %}
    {% elsif section.settings.collection != blank %}
        {% paginate section.settings.collection.products by products_per_page %}
            {% for product in section.settings.collection.products %}
                {% content_for 'block', id: 'product_card', type: 'product', closest.product: product %}
            {% endfor %}

            {% if block.settings.show_pagination and paginate.pages > 1 %}
                <nav class="tiendu-pagination" aria-label="Paginación de productos">
                    {{ paginate | default_pagination }}
                </nav>
            {% endif %}
        {% endpaginate %}
    {% elsif design_mode or preview_mode %}
        {% for _i in (1..products_per_page) %}
            {% content_for 'block', id: 'product_card', type: 'product', closest.product: null %}
        {% endfor %}
    {% endif %}
</div>

{% schema %}
{
    "name": "Productos de colección",
    "max_blocks": 1,
    "settings": [
        {
            "type": "number",
            "id": "products_per_page",
            "label": "Productos por página",
            "default": 12
        },
        {
            "type": "checkbox",
            "id": "show_pagination",
            "label": "Mostrar paginación",
            "default": false
        }
    ],
    "blocks": [
        {
            "type": "product"
        }
    ],
    "presets": [
        {
            "name": "Productos de colección",
            "blocks": {
                "product_card": {
                    "type": "product",
                    "static": true,
                    "blocks": {
                        "card_wrap": {
                            "type": "layout",
                            "settings": {
                                "css_styles_desktop": "display: flex; flex-direction: column; gap: 8px;"
                            },
                            "blocks": {
                                "card_image": {
                                    "type": "product__image",
                                    "settings": {
                                        "transition_to_second_image": false
                                    },
                                    "blocks": {
                                        "default-image": {
                                            "type": "image",
                                            "static": true,
                                            "settings": {
                                                "size": "full",
                                                "image_ratio": "product_default",
                                                "rounding": "theme"
                                            }
                                        }
                                    },
                                    "block_order": [
                                        "default-image"
                                    ]
                                },
                                "card_title": {
                                    "type": "product__title",
                                    "blocks": {
                                        "default-text": {
                                            "type": "text",
                                            "static": true,
                                            "settings": {
                                                "custom_color": "#000000"
                                            }
                                        }
                                    },
                                    "block_order": [
                                        "default-text"
                                    ]
                                },
                                "card_pricing": {
                                    "type": "layout",
                                    "settings": {
                                        "css_styles_desktop": "display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;"
                                    },
                                    "blocks": {
                                        "card_price": {
                                            "type": "product__price",
                                            "blocks": {
                                                "default-text": {
                                                    "type": "text",
                                                    "static": true,
                                                    "settings": {
                                                        "custom_color": "#000000",
                                                        "bold": true
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "default-text"
                                            ]
                                        },
                                        "card_compare_price": {
                                            "type": "product__compare-price",
                                            "blocks": {
                                                "default-text": {
                                                    "type": "text",
                                                    "static": true,
                                                    "settings": {
                                                        "custom_color": "#94a3b8",
                                                        "line_through": true
                                                    }
                                                }
                                            },
                                            "block_order": [
                                                "default-text"
                                            ]
                                        }
                                    },
                                    "block_order": [
                                        "card_price",
                                        "card_compare_price"
                                    ]
                                }
                            },
                            "block_order": [
                                "card_image",
                                "card_title",
                                "card_pricing"
                            ]
                        }
                    },
                    "block_order": [
                        "card_wrap"
                    ]
                }
            },
            "block_order": [
                "product_card"
            ]
        }
    ]
}
{% endschema %}
