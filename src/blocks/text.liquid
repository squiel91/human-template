{% assign generated_text_id = 'tiendu__text-' | append: section.id | append: '-' | append: block.id %}
{% assign text_size_desktop = block.settings.size_desktop %}
{% assign text_size_tablet = block.settings.size_tablet %}
{% assign text_size_mobile = block.settings.size_mobile %}
{% assign text_color_option = block.settings.color | default: 'custom' %}
{% assign text_content = block.settings.text | default: default_text | default: default_content %}
{% assign text_type = block.settings.text_type | default: 'text' %}
{% assign text_id = text_id | default: generated_text_id %}
{% assign text_class = text_class | default: '' %}
{% assign vertical_margin = block.settings.vertical_margin | default: 'none' %}

{% case text_type %}
    {% when 'paragraph' %}
        {% assign text_tag = 'p' %}
        {% assign text_font_family = 'var(--font-body-family)' %}
    {% when 'page_title' %}
        {% assign text_tag = 'h1' %}
        {% assign text_font_family = 'var(--font-heading-family)' %}
    {% when 'section_title' %}
        {% assign text_tag = 'h2' %}
        {% assign text_font_family = 'var(--font-heading-family)' %}
    {% when 'subtitle' %}
        {% assign text_tag = 'h3' %}
        {% assign text_font_family = 'var(--font-heading-family)' %}
    {% when 'heading_4' %}
        {% assign text_tag = 'h4' %}
        {% assign text_font_family = 'var(--font-heading-family)' %}
    {% when 'heading_5' %}
        {% assign text_tag = 'h5' %}
        {% assign text_font_family = 'var(--font-heading-family)' %}
    {% else %}
        {% assign text_tag = 'span' %}
        {% assign text_font_family = 'var(--font-body-family)' %}
{% endcase %}

{% case text_color_option %}
    {% when 'automatic' %}
        {% assign text_color = settings.text_color | default: '#000000' %}
    {% when 'secondary' %}
        {% assign text_color = settings.secondary_color | default: '#00FF00' %}
    {% when 'accent' %}
        {% assign text_color = settings.accent_color | default: '#FF0000' %}
    {% when 'custom' %}
        {% assign text_color = block.settings.custom_color %}
    {% else %}
        {% assign text_color = settings.primary_color | default: '#0000FF' %}
{% endcase %}

{% case block.settings.alignment %}
    {% when 'left' %}
        {% assign text_alignment = 'left' %}
    {% when 'center' %}
        {% assign text_alignment = 'center' %}
    {% when 'justify' %}
        {% assign text_alignment = 'justify' %}
    {% when 'right' %}
        {% assign text_alignment = 'right' %}
    {% else %}
        {% assign text_alignment = '' %}
{% endcase %}

{% capture text_decoration %}
    {% if block.settings.underline %}underline{% endif %}{% if block.settings.underline and block.settings.line_through %} {% endif %}{% if block.settings.line_through %}line-through{% endif %}
{% endcapture %}
{% assign text_decoration_value = text_decoration | strip %}

{% capture text_classes %}
    tiendu-text
    {% if vertical_margin == 'none' %}
        tiendu-no-default-margin
    {% endif %}
    {% if text_size_desktop != 'inherit' %}
        text-{{ text_size_desktop }}
    {% endif %}
    {% if text_size_tablet == 'inherit' %}
        tablet:text-inherit
    {% elsif text_size_tablet != blank %}
        tablet:text-{{ text_size_tablet }}
    {% endif %}
    {% if text_size_mobile == 'inherit' %}
        mobile:text-inherit
    {% elsif text_size_mobile != blank %}
        mobile:text-{{ text_size_mobile }}
    {% endif %}
{% endcapture %}

<style>
    #{{ text_id }} {
        font-family: {{ text_font_family }};
        {% if text_color != blank %}
            color: {{ text_color }};
        {% endif %}
        {% if block.settings.bold %}
            font-weight: 700;
        {% endif %}
        {% if block.settings.italic %}
            font-style: italic;
        {% endif %}
        {% if text_decoration_value != blank %}
            text-decoration: {{ text_decoration_value }};
        {% endif %}
        {% if text_alignment != blank %}
            text-align: {{ text_alignment }};
        {% endif %}
        {{ block.settings.css_styles_desktop }}
    }

    @media (width <= 64rem) {
        #{{ text_id }} {
            {{ block.settings.css_styles_tablet }}
        }
    }

    @media (width <= 48rem) {
        #{{ text_id }} {
            {{ block.settings.css_styles_mobile }}
        }
    }
</style>

<{{ text_tag }}
    {{ block.tiendu_attributes }}
    id="{{ text_id }}"
    class="{{ text_classes | strip }} {{ text_class | strip }}"
>
    {{ text_content }}
</{{ text_tag }}>

