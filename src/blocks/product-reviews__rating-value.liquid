{% assign product_obj = closest.product | default: product %}
{% assign child_blocks = block.children | default: block.blocks %}

{% assign average_rating = product_obj.averageRating %}

{% assign product_reviews = product_obj.reviews %}
{% if request.page_type == 'product' and product_page.reviews != blank %}
    {% assign product_reviews = product_page.reviews %}
{% endif %}

{% if average_rating == blank %}
    {% if product_reviews and product_reviews.size > 0 %}
        {% assign total_rating = 0 %}
        {% for review in product_reviews %}
            {% assign total_rating = total_rating | plus: review.rating %}
        {% endfor %}
        {% assign average_rating = total_rating | times: 1.0 | divided_by: product_reviews.size %}
    {% endif %}
{% endif %}

{% assign rating_value = average_rating | default: 0 | round: 1 %}
{% assign rating_text = rating_value | append: '' %}
{% unless rating_text contains '.' %}
    {% assign rating_text = rating_text | append: '.0' %}
{% endunless %}

<div {{ block.tiendu_attributes }}>
    {% if child_blocks and child_blocks.size > 0 %}
        {% for child_block in child_blocks %}
            {% content_for 'block', id: child_block.id, type: child_block.type, default_text: rating_text %}
        {% endfor %}
    {% else %}
        {% content_for 'block', id: 'text', type: 'text', default_text: rating_text %}
    {% endif %}
</div>

{% schema %}
{
    "name": "product reviews: rating value",
    "max_blocks": 1,
    "settings": [],
    "blocks": [
        {
            "type": "text"
        }
    ],
    "presets": [
        {
            "name": "product reviews: rating value",
            "blocks": {
                "text": {
                    "type": "text",
                    "static": true,
                    "settings": {
                        "font_weight": "700",
                        "size_desktop": "5xl",
                        "css_styles_desktop": "line-height: 1;"
                    }
                }
            },
            "block_order": [
                "text"
            ]
        }
    ]
}
{% endschema %}
