{% assign button_id = 'tiendu__button-' | append: section.id | append: '-' | append: block.id %}
{% assign button_action = block.settings.action | default: 'none' %}
{% assign action_product = closest.product | default: product %}
{% assign action_variant = blank %}
{% if action_product and action_product.variants and action_product.variants.size > 0 %}
    {% assign action_variant = action_product.variants.first %}
{% endif %}
{% assign button_has_loading_state = false %}
{% if button_action == 'search' or button_action == 'cart' or button_action == 'add_to_cart' %}
    {% assign button_has_loading_state = true %}
{% endif %}

<style>
    #{{ button_id }} {
        {{ block.settings.css_styles_desktop }}
    }

    @media (width <= 64rem) {
        #{{ button_id }} {
            {{ block.settings.css_styles_tablet }}
        }
    }

    @media (width <= 48rem) {
        #{{ button_id }} {
            {{ block.settings.css_styles_mobile }}
        }
    }

    #{{ button_id }} .tiendu-button__badge {
        position: absolute;
        top: 0;
        right: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.1rem;
        height: 1.1rem;
        padding: 0;
        border-radius: 9999px;
        background-color: var(--primary-color);
        color: white;
        font-size: 0.75rem;
        font-weight: 700;
        line-height: 1;
    }

    #{{ button_id }} .tiendu-button__badge[hidden] {
        display: none;
    }

    #{{ button_id }} .tiendu-button__loader {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: {{ settings.text_color | default: '#000000' }};
    }

    #{{ button_id }} .tiendu-button__loader[hidden] {
        display: none;
    }

    #{{ button_id }} .tiendu-button__loader svg {
        animation: tiendu-spin 1s linear infinite;
        transform-origin: center;
    }

    #{{ button_id }} .tiendu-button__content {
        display: contents;
    }
</style>

<button
    {{ block.tiendu_attributes }}
    class="tiendu-button"
    id="{{ button_id }}"
    type="{% if button_action == 'submit' %}submit{% else %}button{% endif %}"
    {% if button_action != 'none' and button_action != 'submit' %}data-button-action="{{ button_action }}"{% endif %}
    {% if button_action == 'add_to_cart' and action_variant != blank %}data-product-variant-id="{{ action_variant.id }}"{% endif %}
    {% if button_action == 'share' %}data-share-label{% endif %}
>
    <span class="tiendu-button__content" data-button-content>
        {% content_for 'blocks' %}
    </span>
    {% if button_has_loading_state %}
        <span class="tiendu-button__loader" data-button-loader hidden>
            {% render 'icon-loader-circle', size: 24, stroke_width: 2 %}
        </span>
    {% endif %}
    {% if button_action == 'cart' %}
        <span class="tiendu-button__badge" id="cart-quantity-badge" hidden>0</span>
    {% endif %}
</button>

{% schema %}
{
    "name": "Button",
    "settings": [
        {
            "type": "select",
            "id": "action",
            "label": "Action",
            "default": "none",
            "options": [
                {
                    "value": "none",
                    "label": "None"
                },
                {
                    "value": "menu",
                    "label": "Open menu"
                },
                {
                    "value": "close_menu",
                    "label": "Close menu"
                },
                {
                    "value": "close_popup",
                    "label": "Close popup"
                },
                {
                    "value": "search",
                    "label": "Open search"
                },
                {
                    "value": "cart",
                    "label": "Open cart"
                },
                {
                    "value": "add_to_cart",
                    "label": "Add to cart"
                },
                {
                    "value": "share",
                    "label": "Share"
                },
                {
                    "value": "submit",
                    "label": "Submit form"
                }
            ]
        },
        {
            "type": "textarea",
            "id": "css_styles_desktop",
            "label": "CSS styles",
            "info": "Styles will be inherited for other sizes unless overridden."
        },
        {
            "type": "header",
            "content": "Tablet"
        },
        {
            "type": "textarea",
            "id": "css_styles_tablet",
            "label": "CSS styles",
            "info": "Styles will be inherited for phones unless overridden."
        },
        {
            "type": "header",
            "content": "Mobile"
        },
        {
            "type": "textarea",
            "id": "css_styles_mobile",
            "label": "CSS styles",
            "info": "Only applied to phone format."
        }
    ],
    "blocks": [
        {
            "type": "@theme"
        }
    ],
    "presets": [
        {
            "name": "primary",
            "settings": {
                "css_styles_desktop": "position: relative;\ndisplay: flex;\nalign-items: center;\njustify-content: center;\ngap: 8px;\ntext-decoration: none;\ncursor: pointer;\nborder: none;\nfont-family: inherit;\nline-height: 1;\nfont-weight: bold;\ntext-transform: uppercase;\npadding: 0.75rem 1.125rem;\nfont-size: 1rem;\nborder-radius: var(--button-input-border-radius, 0.375rem);\nbackground-color: var(--primary-color);\ncolor: white;\ntransition: opacity 0.2s ease;\n&:hover { opacity: 0.9; }\n&:disabled { opacity: 0.7; cursor: wait; }"
            },
            "blocks": {
                "text": {
                    "type": "text",
                    "settings": {
                        "text": "Click me"
                    }
                }
            },
            "block_order": [
                "text"
            ]
        },
        {
            "name": "secondary",
            "settings": {
                "css_styles_desktop": "position: relative;\ndisplay: flex;\nalign-items: center;\njustify-content: center;\ngap: 8px;\ntext-decoration: none;\ncursor: pointer;\nborder: none;\nfont-family: inherit;\nline-height: 1;\nfont-weight: bold;\ntext-transform: uppercase;\npadding: 0.75rem 1.125rem;\nfont-size: 1rem;\nborder-radius: var(--button-input-border-radius, 0.375rem);\nbackground-color: transparent;\ncolor: var(--primary-color);\ntransition: background-color 0.2s ease;\n&:hover { background-color: rgba(0, 0, 0, 0.06); }\n&:disabled { opacity: 0.7; cursor: wait; }"
            },
            "blocks": {
                "text": {
                    "type": "text",
                    "settings": {
                        "text": "Click me"
                    }
                }
            },
            "block_order": [
                "text"
            ]
        }
    ]
}
{% endschema %}
