{% assign current_collection = blank %}
{% if request.page_type == 'collection' and collection != blank %}
    {% assign current_collection = collection %}
{% elsif section.settings.collection != blank %}
    {% assign current_collection = section.settings.collection %}
{% endif %}
{% assign fallback_text = current_collection.name | default: 'Colección destacada' %}

<div {{ block.shopify_attributes }}>
    {% content_for 'block', id: 'default-text', type: 'text', default_text: fallback_text %}
</div>

{% schema %}
{
    "name": "Texto para colección destacada",
    "max_blocks": 1,
    "blocks": [
        {
            "type": "text"
        }
    ],
    "presets": [
        {
            "name": "Texto para colección destacada",
            "blocks": {
                "default-text": {
                    "type": "text",
                    "static": true,
                    "settings": {
                        "text": "",
                        "text_type": "section_title",
                        "color": "custom",
                        "custom_color": "#000000",
                        "bold": true,
                        "italic": false,
                        "underline": false,
                        "line_through": false,
                        "size_desktop": "2xl",
                        "size_tablet": "",
                        "size_mobile": "",
                        "css_styles_desktop": "",
                        "css_styles_tablet": "",
                        "css_styles_mobile": ""
                    },
                    "blocks": {}
                }
            },
            "block_order": [
                "default-text"
            ]
        }
    ]
}
{% endschema %}
