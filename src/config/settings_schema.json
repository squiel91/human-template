[
    {
        "name": "Colors",
        "settings": [
            {
                "type": "color",
                "id": "primary_color",
                "label": "Primary color",
                "default": "#0000FF"
            },
            {
                "type": "color",
                "id": "secondary_color",
                "label": "Secondary color",
                "default": "#00FF00"
            },
            {
                "type": "color",
                "id": "accent_color",
                "label": "Accent color",
                "default": "#FF0000"
            },
            {
                "type": "color",
                "id": "background_color",
                "label": "Background color",
                "default": "#EFEFEF"
            },
            {
                "type": "color",
                "id": "text_color",
                "label": "Text color",
                "info": "If left empty, the automatic color is used. If not available, black is used."
            }
        ]
    },
    {
        "name": "Animations",
        "settings": [
            {
                "type": "header",
                "content": "Section intro"
            },
            {
                "type": "checkbox",
                "id": "animations",
                "label": "Activate fly in",
                "default": true
            },
            {
                "type": "header",
                "content": "Page transition"
            },
            {
                "type": "checkbox",
                "id": "activate_page_transition",
                "label": "Activate",
                "default": false
            },
            {
                "type": "color",
                "id": "page_transition_background_color",
                "label": "Page transition background color",
                "default": "#FFFFFF"
            },
            {
                "type": "range",
                "id": "page_transition_opacity",
                "label": "Page transition opacity",
                "min": 0,
                "max": 100,
                "step": 5,
                "unit": "%",
                "default": 85
            },
            {
                "type": "image",
                "id": "page_transition_image",
                "label": "Page transition image"
            },
            {
                "type": "range",
                "id": "page_transition_max_time_seconds",
                "label": "Page transition max time",
                "min": 1,
                "max": 10,
                "step": 1,
                "unit": "s",
                "default": 2
            }
        ]
    },
    {
        "name": "Container",
        "settings": [
            {
                "type": "text",
                "id": "max_width",
                "label": "Container max width",
                "placeholder": "1024px",
